---
/**
 * FileTree 文件树组件
 * 用于展示项目目录结构
 *
 * @example
 * <FileTree tree={[
 *   { name: "src/", children: [
 *     { name: "components/", children: [{ name: "Header.astro" }] },
 *     { name: "pages/", children: [{ name: "index.astro" }] },
 *   ]},
 *   { name: "package.json", highlight: true },
 * ]} />
 */
import { Icon } from "astro-icon/components";

interface TreeNode {
  name: string;
  children?: TreeNode[];
  /** 是否高亮标注 */
  highlight?: boolean;
  /** 备注信息 */
  comment?: string;
}

interface Props {
  tree: TreeNode[];
  /** 根目录标题 */
  title?: string;
}

const { tree, title } = Astro.props;
---

<div class="file-tree not-prose my-6 rounded-2xl border border-base-content/12 bg-base-200/40 overflow-hidden shadow-sm">
  {title && (
    <div class="px-4 py-2.5 border-b border-base-content/10 bg-base-200/60 flex items-center gap-2 text-sm font-semibold text-base-content/80">
      <Icon name="lucide:folder-tree" class="w-4 h-4 text-primary" />
      {title}
    </div>
  )}
  <div class="p-4 font-mono text-sm leading-relaxed">
    <ul class="tree-list list-none pl-0 m-0">
      {tree.map((node) => (
        <li class:list={["tree-node", { "is-highlighted": node.highlight }]}>
          <div class="flex items-center gap-1.5 py-0.5">
            {node.children ? (
              <Icon name="lucide:folder" class="w-4 h-4 text-warning shrink-0" />
            ) : (
              <Icon name="lucide:file-text" class="w-4 h-4 text-base-content/50 shrink-0" />
            )}
            <span class:list={["tree-name", { "text-primary font-bold": node.highlight }]}>
              {node.name}
            </span>
            {node.comment && (
              <span class="text-xs text-base-content/40 ml-2 italic">{'// ' + node.comment}</span>
            )}
          </div>
          {node.children && (
            <ul class="tree-list list-none pl-5 m-0 border-l-2 border-base-content/8 ml-2">
              {node.children.map((child) => (
                <li class:list={["tree-node", { "is-highlighted": child.highlight }]}>
                  <div class="flex items-center gap-1.5 py-0.5">
                    {child.children ? (
                      <Icon name="lucide:folder" class="w-4 h-4 text-warning shrink-0" />
                    ) : (
                      <Icon name="lucide:file-text" class="w-4 h-4 text-base-content/50 shrink-0" />
                    )}
                    <span class:list={["tree-name", { "text-primary font-bold": child.highlight }]}>
                      {child.name}
                    </span>
                    {child.comment && (
                      <span class="text-xs text-base-content/40 ml-2 italic">{'// ' + child.comment}</span>
                    )}
                  </div>
                  {child.children && (
                    <ul class="tree-list list-none pl-5 m-0 border-l-2 border-base-content/8 ml-2">
                      {child.children.map((grandchild) => (
                        <li class:list={["tree-node", { "is-highlighted": grandchild.highlight }]}>
                          <div class="flex items-center gap-1.5 py-0.5">
                            {grandchild.children ? (
                              <Icon name="lucide:folder" class="w-4 h-4 text-warning shrink-0" />
                            ) : (
                              <Icon name="lucide:file-text" class="w-4 h-4 text-base-content/50 shrink-0" />
                            )}
                            <span class:list={["tree-name", { "text-primary font-bold": grandchild.highlight }]}>
                              {grandchild.name}
                            </span>
                            {grandchild.comment && (
                              <span class="text-xs text-base-content/40 ml-2 italic">{'// ' + grandchild.comment}</span>
                            )}
                          </div>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .tree-node {
    transition: background-color 0.15s ease;
    border-radius: 0.375rem;
    padding: 0 0.25rem;
  }

  .tree-node:hover {
    background-color: oklch(var(--p) / 0.06);
  }

  .tree-node.is-highlighted {
    background-color: oklch(var(--p) / 0.08);
    border-radius: 0.375rem;
  }
</style>
