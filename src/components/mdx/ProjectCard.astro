---
export interface ProjectCardProps {
  name: string;
  avatar: string;
  description: string;
  url: string;
  badge?: string;
  tags?: string[];
  author?: string;
  github?: string;
}

const { name, avatar, description, url, badge, tags = [], author, github } = Astro.props as ProjectCardProps;

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const MAX_VISIBLE_TAGS = 3;
const visibleTags = tags.slice(0, MAX_VISIBLE_TAGS);
const hiddenTags = tags.slice(MAX_VISIBLE_TAGS);
---

<a 
  href={url} 
  target="_blank" 
  rel="noopener noreferrer"
  class="group block h-full bg-base-100 rounded-2xl border border-base-200 hover:border-primary/40 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden relative"
>
  <div class="p-4 flex flex-col h-full">
    <!-- 头部：图标 + 标题 + Badge -->
    <div class="flex items-start gap-3 mb-2">
      <div class="shrink-0">
        <div class="w-14 h-14 rounded-lg bg-base-200/50 p-1 group-hover:bg-primary/10 transition-colors duration-300">
          <div class="w-full h-full rounded-md overflow-hidden">
            {
              avatar ? (
                <Image src={avatar} width={56} height={56} format="webp" alt={name} loading="lazy" class="object-cover w-full h-full" />
              ) : (
                <div class="flex items-center justify-center w-full h-full bg-base-300 text-base-content/50">
                  <Icon name="lucide:folder" class="w-7 h-7" />
                </div>
              )
            }
          </div>
        </div>
      </div>
      
      <div class="flex-1 min-w-0 pt-0.5">
        <div class="flex items-center gap-2">
          <h3 class="font-bold text-base text-base-content group-hover:text-primary transition-colors truncate" title={name}>
            {name}
          </h3>
          {badge && (
            <span class="shrink-0 inline-flex items-center px-2 py-0.5 text-[10px] font-medium rounded bg-primary/10 text-primary border border-primary/20">
              {badge}
            </span>
          )}
        </div>
        <div class="text-[10px] text-base-content/40 font-mono truncate">
          {new URL(url).hostname}
        </div>
      </div>
    </div>

    <!-- Tags 标签区 -->
    {tags.length > 0 && (
      <div class="flex flex-wrap items-center gap-1.5 mb-2">
        {visibleTags.map((tag) => (
          <span class="px-2 py-0.5 text-[10px] font-medium rounded-full bg-base-200/70 text-base-content/60">
            {tag}
          </span>
        ))}
        {hiddenTags.length > 0 && (
          <div class="project-tag-more relative">
            <span class="px-2 py-0.5 text-[10px] font-medium rounded-full bg-base-200/70 text-base-content/50 cursor-default hover:bg-primary/10 hover:text-primary transition-colors">
              +{hiddenTags.length}
            </span>
            <div class="project-tag-dropdown absolute left-0 top-full mt-1 z-20 hidden bg-base-100 rounded-lg shadow-lg border border-base-200 p-2 min-w-max">
              <div class="flex flex-wrap gap-1.5 max-w-[200px]">
                {hiddenTags.map((tag) => (
                  <span class="px-2 py-0.5 text-[10px] font-medium rounded-full bg-base-200/70 text-base-content/60">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- 描述 -->
    <p class="text-xs text-base-content/70 line-clamp-2 leading-relaxed mb-2 flex-grow">
      {description}
    </p>

    <!-- 底部信息栏 -->
    <div class="flex items-center justify-between pt-2 border-t border-base-200/50 mt-auto">
      <div class="flex items-center gap-2 text-xs text-base-content/50 min-w-0">
        {author && (
          <span class="flex items-center gap-1 truncate">
            <Icon name="lucide:user" class="w-3 h-3 shrink-0" />
            <span class="truncate">{author}</span>
          </span>
        )}
        {github && (
          <Icon name="lucide:github" class="w-3.5 h-3.5 shrink-0 opacity-40 group-hover:opacity-70 transition-opacity" />
        )}
      </div>
      
      <div class="text-xs font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-1 shrink-0">
        查看详情
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
      </div>
    </div>
  </div>
</a>

<style>
  .project-tag-more:hover .project-tag-dropdown {
    display: block;
  }
</style>
