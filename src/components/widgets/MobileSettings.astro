---
import { Icon } from "astro-icon/components";
import TranslateWidget from "./TranslateWidget.astro";
import ThemeToggle from "./ThemeToggle.astro";

const themes = [
  { name: "light", color: "#ffffff" },
  { name: "dark", color: "#1d232a" },
  { name: "cupcake", color: "#65c3c8" },
  { name: "bumblebee", color: "#e0a82e" },
  { name: "emerald", color: "#66cc8a" },
  { name: "corporate", color: "#4b6bfb" },
  { name: "synthwave", color: "#e779c1" },
  { name: "retro", color: "#ef9995" },
  { name: "cyberpunk", color: "#ff7598" },
  { name: "valentine", color: "#e96d7b" },
  { name: "halloween", color: "#f28c18" },
  { name: "garden", color: "#fe0075" },
  { name: "forest", color: "#1eb854" },
  { name: "aqua", color: "#09ecf3" },
  { name: "lofi", color: "#808080" },
  { name: "pastel", color: "#d1c1d7" },
  { name: "fantasy", color: "#6e0b75" },
  { name: "wireframe", color: "#b8b8b8" },
  { name: "black", color: "#000000" },
  { name: "luxury", color: "#ffffff" },
  { name: "dracula", color: "#ff79c6" },
  { name: "cmyk", color: "#45AEEE" },
  { name: "autumn", color: "#8C0327" },
  { name: "business", color: "#1C4E80" },
  { name: "acid", color: "#FF00F4" },
  { name: "lemonade", color: "#519903" },
  { name: "night", color: "#38bdf8" },
  { name: "coffee", color: "#DB924B" },
  { name: "winter", color: "#047AFF" },
];

const fonts = [
  { value: "system-ui, -apple-system, sans-serif", label: "System UI", preview: "system-ui" },
  { value: "'Noto Sans SC', sans-serif", label: "Noto Sans SC", preview: "'Noto Sans SC'" },
  { value: "'Noto Serif SC', serif", label: "Noto Serif SC", preview: "'Noto Serif SC'" },
  { value: "'LXGW WenKai', cursive", label: "LXGW WenKai", preview: "'LXGW WenKai'" },
  { value: "'Ma Shan Zheng', cursive", label: "Ma Shan Zheng", preview: "'Ma Shan Zheng'" },
  { value: "'ZCOOL XiaoWei', serif", label: "ZCOOL XiaoWei", preview: "'ZCOOL XiaoWei'" },
  { value: "'Long Cang', cursive", label: "Long Cang", preview: "'Long Cang'" },
  { value: "'ZCOOL QingKe HuangYou', cursive", label: "ZCOOL QingKe HuangYou", preview: "'ZCOOL QingKe HuangYou'" },
  { value: "'ZCOOL KuaiLe', cursive", label: "ZCOOL KuaiLe", preview: "'ZCOOL KuaiLe'" },
  { value: "'Liu Jian Mao Cao', cursive", label: "Liu Jian Mao Cao", preview: "'Liu Jian Mao Cao'" },
  { value: "'Zhi Mang Xing', cursive", label: "Zhi Mang Xing", preview: "'Zhi Mang Xing'" },
];
---

<div class="dropdown dropdown-end">
  <div tabindex="0" role="button" class="btn btn-ghost btn-circle btn-sm hover:bg-transparent text-primary" title="Settings">
    <Icon name="material-symbols:settings-outline" class="w-6 h-6" />
  </div>

  <ul tabindex="0" class="dropdown-content z-[100] menu p-2 shadow-2xl bg-base-200 rounded-box w-64 mt-4">
    <li>
      <div class="flex justify-between items-center gap-2 p-2 rounded-lg w-full">
        <span class="font-medium">Dark/Light</span>
        <ThemeToggle className="btn btn-ghost btn-circle btn-sm text-primary hover:bg-primary/10 hover:text-primary transition-colors duration-200" />
      </div>
    </li>

    <li>
      <details>
        <summary class="font-medium flex justify-between items-center p-2 hover:bg-base-300 rounded-lg w-full">
          <div class="flex items-center gap-2">
            <Icon name="material-symbols:image-outline" class="w-5 h-5" />
            Banner Mode
          </div>
        </summary>
        <ul class="p-2 bg-base-100 rounded-box">
          <li>
            <button data-set-banner-mobile="normal" class="flex gap-2">
              <Icon name="material-symbols:panorama-outline" class="w-5 h-5" />
              Normal
            </button>
          </li>
          <li>
            <button data-set-banner-mobile="fullscreen" class="flex gap-2">
              <Icon name="material-symbols:fullscreen" class="w-5 h-5" />
              Fullscreen
            </button>
          </li>
          <li>
            <button data-set-banner-mobile="background" class="flex gap-2">
              <Icon name="material-symbols:wallpaper" class="w-5 h-5" />
              Background
            </button>
          </li>
          <li>
            <button data-set-banner-mobile="hidden" class="flex gap-2">
              <Icon name="material-symbols:hide-image-outline" class="w-5 h-5" />
              Hidden
            </button>
          </li>
        </ul>
      </details>
    </li>

    <li>
      <details>
        <summary class="font-medium flex justify-between items-center p-2 hover:bg-base-300 rounded-lg w-full">
          <div class="flex items-center gap-2">
            <Icon name="material-symbols:font-download-outline" class="w-5 h-5" />
            Font
          </div>
        </summary>
        <ul class="p-2 bg-base-100 rounded-box max-h-60 overflow-y-auto flex-nowrap">
          {fonts.map((font) => (
            <li>
              <button data-set-font={font.value} class="flex gap-3 items-center">
                <span style={`font-family: ${font.preview};`}>Aa</span>
                <span>{font.label}</span>
              </button>
            </li>
          ))}
        </ul>
      </details>
    </li>

    <TranslateWidget variant="inline" />

    <li>
      <a href="/config" class="flex justify-between items-center p-2 hover:bg-base-300 rounded-lg w-full">
        <div class="flex items-center gap-2">
          <Icon name="material-symbols:settings-outline" class="w-5 h-5" />
          <span class="font-medium">站点配置</span>
        </div>
      </a>
    </li>

    <li>
      <details>
        <summary class="font-medium flex justify-between items-center p-2 hover:bg-base-300 rounded-lg w-full">
          <div class="flex items-center gap-2">
            <Icon name="material-symbols:palette-outline" class="w-5 h-5" />
            Theme
          </div>
        </summary>
        <ul class="p-2 bg-base-100 rounded-box max-h-60 overflow-y-auto flex-nowrap">
          {themes.map((theme) => (
            <li>
              <button
                class="flex gap-3 items-center"
                data-set-theme-mobile={theme.name}
                aria-label={`Change theme to ${theme.name}`}
              >
                <span class="w-4 h-4 rounded-full border border-base-content/20" style={`background-color: ${theme.color};`}></span>
                <span class="capitalize">{theme.name}</span>
              </button>
            </li>
          ))}
        </ul>
      </details>
    </li>
  </ul>
</div>

<script is:inline>
  const updateMobileThemeButtons = () => {
    const currentTheme =
      document.documentElement.getAttribute("data-theme") ||
      localStorage.getItem("theme") ||
      "light";

    document.querySelectorAll("[data-set-theme-mobile]").forEach((btn) => {
      const active = btn.getAttribute("data-set-theme-mobile") === currentTheme;
      btn.classList.toggle("bg-primary/10", active);
      btn.classList.toggle("text-primary", active);
      btn.classList.toggle("font-bold", active);
      btn.classList.toggle("active", active);
    });
  };

  const updateActiveBannerButton = () => {
    const currentMode =
      document.documentElement.getAttribute("data-banner-mode") ||
      localStorage.getItem("banner-mode") ||
      "normal";

    document.querySelectorAll("[data-set-banner-mobile]").forEach((btn) => {
      const active = btn.getAttribute("data-set-banner-mobile") === currentMode;
      btn.classList.toggle("bg-primary/10", active);
      btn.classList.toggle("text-primary", active);
      btn.classList.toggle("font-bold", active);
      btn.classList.toggle("active", active);
    });
  };

  const updateActiveFontButton = () => {
    const currentFont =
      document.documentElement.getAttribute("data-font") ||
      localStorage.getItem("blog-font") ||
      "";

    document.querySelectorAll("[data-set-font]").forEach((btn) => {
      const active = btn.getAttribute("data-set-font") === currentFont;
      btn.classList.toggle("bg-primary/10", active);
      btn.classList.toggle("text-primary", active);
      btn.classList.toggle("font-bold", active);
      btn.classList.toggle("active", active);
    });
  };

  if (!window.__mahiroMobileSettingsThemeSyncBound) {
    window.__mahiroMobileSettingsThemeSyncBound = true;
    window.addEventListener("mahiro:theme-change", () => {
      updateMobileThemeButtons();
    });
    document.addEventListener("astro:after-swap", () => {
      window.setTimeout(() => {
        updateMobileThemeButtons();
        updateActiveBannerButton();
        updateActiveFontButton();
      }, 0);
    });
  }

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-set-banner-mobile]").forEach((btn) => {
      if (btn.dataset.bound === "true") return;
      btn.dataset.bound = "true";
      btn.addEventListener("click", () => {
        const mode = btn.getAttribute("data-set-banner-mobile");
        document.documentElement.setAttribute("data-banner-mode", mode);
        localStorage.setItem("banner-mode", mode);
        updateActiveBannerButton();
      });
    });

    document.querySelectorAll("[data-set-theme-mobile]").forEach((btn) => {
      if (btn.dataset.bound === "true") return;
      btn.dataset.bound = "true";
      btn.addEventListener("click", () => {
        const theme = btn.getAttribute("data-set-theme-mobile");
        if (!theme) return;
        window.__mahiroSetThemeTrigger?.(btn);
        window.__mahiroAnimateThemeControl?.(btn);
        window.__mahiroApplyTheme?.(theme, { animate: true });
      });
    });

    document.querySelectorAll("[data-set-font]").forEach((btn) => {
      if (btn.dataset.bound === "true") return;
      btn.dataset.bound = "true";
      btn.addEventListener("click", () => {
        const font = btn.getAttribute("data-set-font");
        if (typeof applyFont === "function") applyFont(font);
        localStorage.setItem("blog-font", font);
        updateActiveFontButton();
      });
    });

    updateMobileThemeButtons();
    updateActiveBannerButton();
    updateActiveFontButton();
  });
</script>
