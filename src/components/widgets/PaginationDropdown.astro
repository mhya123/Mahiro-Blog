---
import type { PaginationDropdownProps } from "@interfaces/data";

const { hiddenPages, current, baseUrl } = Astro.props as PaginationDropdownProps;
const normalizedBaseUrl = baseUrl.replace(/\/+$/, "");

const normalizePath = (value: string) => {
  const cleaned = value.replace(/\/+$/, "");
  return cleaned || "/";
};

const getHref = (page: string | number) => {
  if (page === 1) return normalizedBaseUrl || "/";
  return normalizedBaseUrl ? `${normalizedBaseUrl}/${page}` : `/${page}`;
};

const currentPath = normalizePath(Astro.url.pathname);
---

<div class="dropdown dropdown-top join-item">
  <div tabindex="0" role="button" class="btn join-item bg-base-100">...</div>
  <ul class="dropdown-content z-[100] menu p-2 shadow-xl bg-base-100 rounded-box w-auto mx-auto mt-1">
    {
      hiddenPages.map((page) => {
        const normalizedPage = Number(page);
        const href = getHref(page);
        const isCurrentByPath = normalizePath(href) === currentPath;
        const isCurrentByPage = Number.isFinite(normalizedPage) && normalizedPage === Number(current);
        const isCurrentPage = isCurrentByPath || isCurrentByPage;

        return (
          <li class="w-full">
            <a
              href={href}
              aria-current={isCurrentPage ? "page" : undefined}
              class:list={[
                "text-center py-1 px-3",
                isCurrentPage
                  ? "bg-primary text-primary-content font-semibold pointer-events-none"
                  : "hover:bg-base-200",
              ]}
            >
              {page}
            </a>
          </li>
        );
      })
    }
  </ul>
</div>
