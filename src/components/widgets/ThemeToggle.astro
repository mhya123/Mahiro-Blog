---
import type { ThemeToggleProps } from "@interfaces/data";
import ThemeToggleButton from "./ThemeToggleButton";

const { className = "" } = Astro.props as ThemeToggleProps;
---

<ThemeToggleButton client:load className={className} />

<style is:global>
  .theme-toggles-button {
    position: relative;
  }

  .theme-toggles-button::before {
    content: "";
    position: absolute;
    inset: 50% auto auto 50%;
    width: 1.28rem;
    height: 1.28rem;
    border-radius: 999px;
    background: currentColor;
    mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='black' d='M21.75 15.0a9.75 9.75 0 0 1-12.75-12.75 0.75 0.75 0 0 0-0.9-0.9A10.5 10.5 0 1 0 22.65 15.9a0.75 0.75 0 0 0-0.9-0.9Z'/%3E%3C/svg%3E") center / contain no-repeat;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0.72) rotate(-8deg);
    transition:
      opacity 0.18s ease,
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-toggles-button svg {
    overflow: visible;
    shape-rendering: geometricPrecision;
    transition:
      opacity 0.16s ease,
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-toggles-button .toggles-dev--\[transform-origin\:center\] {
    transform-origin: center;
    transform-box: fill-box;
  }

  .theme-toggles-button .toggles-dev--transition-\[d\,translate\] {
    transition-property: d, translate;
    transition-timing-function: var(--tw-ease, var(--default-transition-timing-function));
    transition-duration: var(--tw-duration, var(--default-transition-duration));
  }

  .theme-toggles-button .toggles-dev--\[transition-delay\:0s\] {
    transition-delay: 0s;
  }

  .theme-toggles-button .toggles-dev--\[transition-duration\:calc\(var\(--toggles-expand--duration\)_\*_0\.6\)\] {
    transition-duration: calc(var(--toggles-expand--duration) * 0.6);
  }

  .theme-toggles-button .toggles-dev--\[transition-timing-function\:cubic-bezier\(0\,0\,0\.5\,1\)\] {
    transition-timing-function: cubic-bezier(0, 0, 0.5, 1);
  }

  .theme-toggles-button .toggles-dev--\[transition\:transform_calc\(var\(--toggles-expand--duration\)_\*_0\.65\)_cubic-bezier\(0\,0\,0\,1\.25\)_calc\(var\(--toggles-expand--duration\)_\*_0\.35\)\] {
    transition: transform calc(var(--toggles-expand--duration) * 0.65) cubic-bezier(0, 0, 0, 1.25) calc(var(--toggles-expand--duration) * 0.35);
  }

  .dark .theme-toggles-button::before {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(-8deg);
  }

  .dark .theme-toggles-button svg {
    opacity: 0;
    transform: scale(0.72) rotate(12deg);
  }
</style>
