---  
import { Icon } from "astro-icon/components";  
import type { ThemeToggleProps } from "@interfaces/data";  
import { t } from "@config";  
  
// Generate a unique ID for each component instance  
const uniqueId = `theme-toggle-${Math.random().toString(36).substring(2, 11)}`;  
  
const { className = "" } = Astro.props as ThemeToggleProps;  
---  
  
<button  
  id={uniqueId}  
  class:list={["btn btn-circle btn-md bg-transparent backdrop-blur-md shadow-sm hover:scale-110", className]}  
  aria-label="Toggle theme"  
  data-theme-toggle  
  title={t("label.themeToggle")}  
>  
  <!-- Moon to sun transition icon (shown when light theme is active) -->  
  <Icon  
    name="line-md:moon-alt-to-sunny-outline-loop-transition"  
    class="theme-toggle-icon h-5 w-5 light-icon"  
    size={20}  
  />  
  
  <!-- Sun to moon transition icon (shown when dark theme is active) -->  
  <Icon  
    name="line-md:sunny-outline-to-moon-alt-loop-transition"  
    class="theme-toggle-icon h-5 w-5 dark-icon hidden"  
    size={20}  
  />  
</button>  
  
<script is:inline define:vars={{ uniqueId }}>  
  const updateThemeIcons = (toggleButton, isDark) => {  
    if (!toggleButton) return;  
  
    const lightIcon = toggleButton.querySelector(".light-icon");  
    const darkIcon = toggleButton.querySelector(".dark-icon");  
  
    if (lightIcon && darkIcon) {  
      lightIcon.classList.toggle("hidden", isDark);  
      darkIcon.classList.toggle("hidden", !isDark);  
    }  
  };  

  const refreshAllThemeToggles = (forcedIsDark) => {
    const currentTheme = document.documentElement.getAttribute("data-theme") || "";
    const resolvedThemeType =
      typeof forcedIsDark === "boolean"
        ? (forcedIsDark ? "dark" : "light")
        : (window.__mahiroResolveThemeType?.(currentTheme) || document.documentElement.getAttribute("data-theme-type") || "light");
    const isDark = resolvedThemeType === "dark";

    document.querySelectorAll("[data-theme-toggle]").forEach((toggleButton) => {
      updateThemeIcons(toggleButton, isDark);
    });
  };

  if (!window.__mahiroThemeToggleSyncBound) {
    window.__mahiroThemeToggleSyncBound = true;
    window.addEventListener("mahiro:theme-change", (event) => {
      refreshAllThemeToggles(Boolean(event.detail?.isDark));
    });
    document.addEventListener("astro:after-swap", () => {
      window.setTimeout(() => refreshAllThemeToggles(), 0);
    });
  }
  
  document.addEventListener("astro:page-load", () => {  
    const themeToggle = document.getElementById(uniqueId);  
    if (!themeToggle) {
      refreshAllThemeToggles();
      return;
    }

    if (themeToggle.dataset.bound !== "true") {
      themeToggle.dataset.bound = "true";
      themeToggle.addEventListener("click", () => {  
        window.__mahiroSetThemeTrigger?.(themeToggle);
        window.__mahiroAnimateThemeControl?.(themeToggle);
        themeToggle.classList.add("animate-spin-once");  
        window.__mahiroToggleTheme?.({ animate: true });
  
        setTimeout(() => {  
          themeToggle.classList.remove("animate-spin-once");  
        }, 220);  
      });
    }

    refreshAllThemeToggles();
  });  
</script>  
  
<style>  
  @keyframes theme-toggle-bump {  
    0% {  
      transform: scale(0.96);  
    }  
    100% {  
      transform: scale(1);  
    }  
  }  
  
  .animate-spin-once {  
    animation: theme-toggle-bump 0.18s ease-out;  
  }  
  
  .theme-toggle-icon {  
    transition:  
      opacity 0.2s ease-in-out,  
      transform 0.2s ease-in-out;  
  }  
</style>
