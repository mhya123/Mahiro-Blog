---
import { Icon } from "astro-icon/components";
---

<button
  id="scroll-to-top"
  aria-label="Scroll to top"
  class="btn btn-circle btn-md fixed bottom-20 right-6 z-[9999]
         bg-base-100/90 backdrop-blur-sm shadow-xl
         border border-base-content/10
         opacity-0 translate-y-6 scale-90 pointer-events-none
         transition-all duration-500 ease-[cubic-bezier(.22,1,.36,1)]
         will-change-[transform,opacity]
         hover:scale-110 hover:shadow-2xl
         hover:bg-primary hover:text-primary-content hover:border-primary/20
         active:scale-95"
  title="Back to top"
>
  <Icon name="material-symbols:arrow-upward-rounded" class="h-5 w-5" />
</button>

<script>
  let scrollListener: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    const scrollButton = document.getElementById("scroll-to-top");
    if (!scrollButton) return;

    let isTicking = false;
    let isVisible = false;

    const updateVisibility = () => {
      const shouldShow = window.scrollY > 300;

      if (shouldShow !== isVisible) {
        isVisible = shouldShow;

        if (shouldShow) {
          scrollButton.classList.remove(
            "opacity-0",
            "translate-y-6",
            "scale-90",
            "pointer-events-none"
          );
          scrollButton.classList.add(
            "opacity-100",
            "translate-y-0",
            "scale-100"
          );
        } else {
          scrollButton.classList.remove(
            "opacity-100",
            "translate-y-0",
            "scale-100"
          );
          scrollButton.classList.add(
            "opacity-0",
            "translate-y-6",
            "scale-90",
            "pointer-events-none"
          );
        }
      }

      isTicking = false;
    };

    scrollListener = () => {
      if (!isTicking) {
        requestAnimationFrame(updateVisibility);
        isTicking = true;
      }
    };

    updateVisibility();

    window.addEventListener("scroll", scrollListener, { passive: true });

    scrollButton.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    });
  });

  document.addEventListener("astro:before-swap", () => {
    if (scrollListener) {
      window.removeEventListener("scroll", scrollListener);
      scrollListener = null;
    }
  });
</script>