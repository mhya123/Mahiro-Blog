---
import { Icon } from "astro-icon/components";
---

<button
  id="back-to-top"
  class="fixed right-6 bottom-[5.5rem] z-[90] p-3 rounded-full bg-primary/90 backdrop-blur-md text-primary-content shadow-xl opacity-0 translate-y-8 cursor-pointer pointer-events-none hover:scale-110 hover:shadow-2xl transition-all duration-300"
  aria-label="返回顶部"
>
  <Icon name="lucide:arrow-up" class="w-6 h-6" />
</button>

<script>
  import anime from "animejs";

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;

    let isVisible = false;

    const handleScroll = () => {
      const currentScroll = window.scrollY || document.documentElement.scrollTop;
      
      // 当滑动超过 400px 时显示
      if (currentScroll > 400 && !isVisible) {
        isVisible = true;
        btn.style.pointerEvents = "auto";
        anime({
          targets: btn,
          opacity: [0, 1],
          translateY: [32, 0],
          duration: 600,
          easing: "easeOutElastic(1, .8)"
        });
      } else if (currentScroll <= 400 && isVisible) {
        isVisible = false;
        btn.style.pointerEvents = "none";
        anime({
          targets: btn,
          opacity: 0,
          translateY: 32,
          duration: 300,
          easing: "easeInQuad"
        });
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // 初始化检查

    // 点击流畅滑回顶部
    btn.addEventListener("click", () => {
      const scrollObj = { y: window.scrollY };
      
      anime({
        targets: scrollObj,
        y: 0,
        duration: 800,
        easing: "easeInOutQuart",
        update: function() {
          window.scrollTo(0, scrollObj.y);
        }
      });
    });
  });
</script>
