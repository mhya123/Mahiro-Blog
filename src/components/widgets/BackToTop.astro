---
import { Icon } from "astro-icon/components";
---

<button
  id="back-to-top"
  class="group fixed right-6 bottom-[5.5rem] z-[90] grid h-12 w-12 place-items-center rounded-full border border-primary-content/10 bg-primary/85 text-primary-content shadow-[0_18px_40px_-20px_oklch(var(--p)/0.9)] opacity-0 pointer-events-none backdrop-blur-xl will-change-[transform,opacity] transition-[box-shadow,background-color,border-color,transform] duration-300 hover:-translate-y-1 hover:scale-[1.03] hover:bg-primary hover:shadow-[0_24px_48px_-20px_oklch(var(--p)/1)] active:scale-95"
  aria-label="返回顶部"
>
  <span
    id="back-to-top-glow"
    class="pointer-events-none absolute inset-0 rounded-full bg-primary/35 opacity-0 blur-md"
    aria-hidden="true"
  ></span>
  <span
    id="back-to-top-icon"
    class="relative z-10 flex items-center justify-center"
  >
    <Icon name="lucide:arrow-up" class="h-5 w-5" />
  </span>
</button>

<script>
  import { animate, remove } from "animejs";

  let scrollHandler = null;
  let clickHandler = null;
  let rafId = null;
  let scrollTweenState = null;

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("back-to-top");
    const glow = document.getElementById("back-to-top-glow");
    const icon = document.getElementById("back-to-top-icon");
    if (!btn || !glow || !icon) return;

    let isVisible = false;

    const stopAnimations = () => {
      remove(btn);
      remove(glow);
      remove(icon);
      if (scrollTweenState) {
        remove(scrollTweenState);
      }
    };

    const playShowAnimation = () => {
      animate(btn, {
        opacity: [0, 1],
        translateY: [22, 0],
        scale: [0.82, 1],
        rotate: [-10, 0],
        duration: 520,
        ease: "outBack(1.4)",
      });

      animate(icon, {
        translateY: [8, 0],
        scale: [0.75, 1],
        duration: 480,
        ease: "outBack(1.6)",
      });

      animate(glow, {
        opacity: [0, 0.45, 0],
        scale: [0.7, 1.65],
        duration: 700,
        ease: "outCubic",
      });
    };

    const playHideAnimation = () => {
      animate(btn, {
        opacity: 0,
        translateY: 18,
        scale: 0.9,
        rotate: 0,
        duration: 180,
        ease: "inQuad",
      });

      animate(icon, {
        translateY: 0,
        scale: 0.92,
        duration: 180,
        ease: "inQuad",
      });
    };

    const playClickAnimation = () => {
      animate(btn, {
        scale: [1, 0.9, 1.02],
        duration: 260,
        ease: "outBack(1.5)",
      });

      animate(icon, {
        translateY: [0, -6, 0],
        duration: 320,
        ease: "outQuad",
      });

      animate(glow, {
        opacity: [0, 0.5, 0],
        scale: [0.8, 1.9],
        duration: 520,
        ease: "outCubic",
      });
    };

    const setVisible = (shouldShow) => {
      if (shouldShow === isVisible) return;

      isVisible = shouldShow;
      stopAnimations();
      btn.style.pointerEvents = shouldShow ? "auto" : "none";

      if (shouldShow) {
        playShowAnimation();
        return;
      }

      playHideAnimation();
    };

    const updateVisibility = () => {
      const currentScroll = window.scrollY || document.documentElement.scrollTop;
      setVisible(currentScroll > 420);
    };

    scrollHandler = () => {
      if (rafId !== null) return;
      rafId = window.requestAnimationFrame(() => {
        updateVisibility();
        rafId = null;
      });
    };

    clickHandler = () => {
      const currentY = window.scrollY || document.documentElement.scrollTop;
      if (currentY <= 0) return;

      stopAnimations();
      playClickAnimation();
      scrollTweenState = { y: currentY };

      animate(scrollTweenState, {
        y: 0,
        duration: Math.min(950, Math.max(480, currentY * 0.42)),
        ease: "inOutQuart",
        onUpdate: () => {
          window.scrollTo(0, scrollTweenState.y);
        },
        onComplete: () => {
          scrollTweenState = null;
        },
      });
    };

    window.addEventListener("scroll", scrollHandler, { passive: true });
    btn.addEventListener("click", clickHandler);
    updateVisibility();
  });

  document.addEventListener("astro:before-swap", () => {
    const btn = document.getElementById("back-to-top");
    const glow = document.getElementById("back-to-top-glow");
    const icon = document.getElementById("back-to-top-icon");

    if (scrollHandler) {
      window.removeEventListener("scroll", scrollHandler);
      scrollHandler = null;
    }

    if (btn && clickHandler) {
      btn.removeEventListener("click", clickHandler);
      clickHandler = null;
    }

    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }

    if (btn) {
      remove(btn);
    }

    if (glow) {
      remove(glow);
    }

    if (icon) {
      remove(icon);
    }

    if (scrollTweenState) {
      remove(scrollTweenState);
      scrollTweenState = null;
    }
  });
</script>
