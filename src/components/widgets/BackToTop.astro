---
import { Icon } from "astro-icon/components";
---

<button
  id="back-to-top"
  class="group fixed right-6 bottom-[5.5rem] z-[90] grid h-12 w-12 place-items-center rounded-full border border-primary-content/10 bg-primary/85 text-primary-content shadow-[0_18px_40px_-20px_oklch(var(--p)/0.9)] opacity-0 pointer-events-none backdrop-blur-xl will-change-[transform,opacity] transition-[box-shadow,background-color,border-color,transform,opacity] duration-300 hover:-translate-y-1 hover:scale-[1.03] hover:bg-primary hover:shadow-[0_24px_48px_-20px_oklch(var(--p)/1)] active:scale-95"
  aria-label="返回顶部"
>
  <span
    id="back-to-top-glow"
    class="pointer-events-none absolute inset-0 rounded-full bg-primary/35 opacity-0 blur-md"
    aria-hidden="true"
  ></span>
  <span
    id="back-to-top-icon"
    class="relative z-10 flex items-center justify-center"
  >
    <Icon name="lucide:arrow-up" class="h-5 w-5" />
  </span>
</button>

<script>
  import { animate, remove } from "animejs";

  let scrollHandler: (() => void) | null = null;
  let clickHandler: (() => void) | null = null;
  let rafId: number | null = null;

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("back-to-top");
    const glow = document.getElementById("back-to-top-glow");
    const icon = document.getElementById("back-to-top-icon");
    if (!btn || !glow || !icon) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const SHOW_THRESHOLD = 360;
    let isVisible = false;

    const stopAnimations = () => {
      remove(btn);
      remove(glow);
      remove(icon);
    };

    const playShowAnimation = () => {
      if (prefersReducedMotion) {
        btn.style.opacity = "1";
        btn.style.transform = "translateY(0) scale(1)";
        return;
      }

      animate(btn, {
        opacity: [0, 1],
        translateY: [16, 0],
        scale: [0.9, 1],
        duration: 380,
        ease: "outExpo",
      });

      animate(icon, {
        translateY: [6, 0],
        scale: [0.92, 1],
        duration: 320,
        ease: "outQuad",
      });

      animate(glow, {
        opacity: [0, 0.35, 0],
        scale: [0.8, 1.45],
        duration: 520,
        ease: "outCubic",
      });
    };

    const playHideAnimation = () => {
      if (prefersReducedMotion) {
        btn.style.opacity = "0";
        btn.style.transform = "translateY(8px) scale(0.96)";
        return;
      }

      animate(btn, {
        opacity: 0,
        translateY: 8,
        scale: 0.96,
        duration: 160,
        ease: "inSine",
      });

      animate(icon, {
        translateY: 0,
        scale: 0.96,
        duration: 140,
        ease: "inSine",
      });
    };

    const playClickAnimation = () => {
      if (prefersReducedMotion) return;

      animate(btn, {
        scale: [1, 0.94, 1],
        duration: 220,
        ease: "outQuad",
      });

      animate(icon, {
        translateY: [0, -4, 0],
        duration: 240,
        ease: "outQuad",
      });

      animate(glow, {
        opacity: [0, 0.35, 0],
        scale: [0.9, 1.6],
        duration: 420,
        ease: "outCubic",
      });
    };

    const setVisible = (shouldShow: boolean) => {
      if (shouldShow === isVisible) return;

      isVisible = shouldShow;
      stopAnimations();
      btn.style.pointerEvents = shouldShow ? "auto" : "none";

      if (shouldShow) {
        playShowAnimation();
        return;
      }

      playHideAnimation();
    };

    const updateVisibility = () => {
      const currentScroll = window.scrollY || document.documentElement.scrollTop;
      setVisible(currentScroll > SHOW_THRESHOLD);
    };

    scrollHandler = () => {
      if (rafId !== null) return;
      rafId = window.requestAnimationFrame(() => {
        updateVisibility();
        rafId = null;
      });
    };

    clickHandler = () => {
      playClickAnimation();
      window.scrollTo({
        top: 0,
        behavior: prefersReducedMotion ? "auto" : "smooth",
      });
    };

    window.addEventListener("scroll", scrollHandler, { passive: true });
    btn.addEventListener("click", clickHandler);
    updateVisibility();
  });

  document.addEventListener("astro:before-swap", () => {
    const btn = document.getElementById("back-to-top");
    const glow = document.getElementById("back-to-top-glow");
    const icon = document.getElementById("back-to-top-icon");

    if (scrollHandler) {
      window.removeEventListener("scroll", scrollHandler);
      scrollHandler = null;
    }

    if (btn && clickHandler) {
      btn.removeEventListener("click", clickHandler);
      clickHandler = null;
    }

    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }

    if (btn) {
      remove(btn);
    }

    if (glow) {
      remove(glow);
    }

    if (icon) {
      remove(icon);
    }

  });
</script>
