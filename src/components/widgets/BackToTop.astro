---
import { Icon } from "astro-icon/components";
---

<button
  id="back-to-top"
  class="fixed right-6 bottom-[5.5rem] z-[90] p-3 rounded-full bg-primary/90 backdrop-blur-md text-primary-content shadow-xl opacity-0 translate-y-8 scale-90 cursor-pointer pointer-events-none hover:scale-110 hover:shadow-2xl transition-all duration-300"
  aria-label="返回顶部"
>
  <Icon name="lucide:arrow-up" class="w-6 h-6" />
</button>

<script>
  // 采用通用的导入方式，避免 ts(1192) 没有默认导出的报错
  import * as animejs from "animejs";

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;

    // 兼容不同版本的 animejs 导出格式获取执行函数
    const anime = (animejs as any).default || (animejs as any).anime || animejs;

    let isVisible = false;

    // 简单节流，避免滚动时频繁触发动画
    let scrollTimeout: number | null = null;

    const handleScrollRaw = () => {
      const currentScroll = window.scrollY || document.documentElement.scrollTop;
      
      // 当滑动超过 400px 时显示
      if (currentScroll > 400 && !isVisible) {
        isVisible = true;
        btn.style.pointerEvents = "auto";
        anime({
          targets: btn,
          opacity: [0, 1],
          translateY: [24, 0],
          scale: [0.9, 1],
          duration: 420,
          easing: "easeOutCubic"
        });
      } else if (currentScroll <= 400 && isVisible) {
        isVisible = false;
        btn.style.pointerEvents = "none";
        anime({
          targets: btn,
          opacity: 0,
          translateY: 24,
          scale: 0.9,
          duration: 260,
          easing: "easeInCubic"
        });
      }
    };

    const handleScroll = () => {
      if (scrollTimeout !== null) {
        return;
      }
      scrollTimeout = window.requestAnimationFrame(() => {
        scrollTimeout = null;
        handleScrollRaw();
      });
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // 初始化检查

    // 点击流畅滑回顶部
    btn.addEventListener("click", () => {
      const scrollObj = { y: window.scrollY };
      
      anime.remove(scrollObj);
      anime({
        targets: scrollObj,
        y: 0,
        duration: 600,
        easing: "easeInOutCubic",
        update: function() {
          window.scrollTo(0, scrollObj.y);
        }
      });
    });
  });
</script>
