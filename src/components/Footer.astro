---
import { Icon } from "astro-icon/components";
import { USER_NAME, USER_SITE, USER_FOOTER_SOCIAL_ICONS, SITE_ICP, SITE_ICP_LINK, SITE_POLICE_BEIAN, SITE_POLICE_BEIAN_LINK, GITHUB_CONFIG, SITE_TITLE, SITE_DESCRIPTION } from "@config";
import { getBuildInfo } from "@/lib/build-info";
import dayjs from "@utils/dayjs";
import { getAllPosts } from "@utils/blogUtils";

const owner = GITHUB_CONFIG?.owner || '';
const repo = GITHUB_CONFIG?.repo || '';
const buildInfo = await getBuildInfo(owner, repo);
const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const startYear = 2025;
const currentYear = new Date().getFullYear();
const yearDisplay = startYear === currentYear ? `${currentYear}` : `${startYear}–${currentYear}`;
---

<footer class="bg-base-100 py-6 px-4 md:px-10 md:py-8 rounded-2xl shadow-lg flex flex-col gap-6">
  <!-- 上半部分：品牌 + 导航 + 社交 三栏 -->
  <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    
    <!-- 左栏：品牌信息 -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
          <Icon name="lucide:heart" class="w-5 h-5 text-primary" />
        </div>
        <div>
          <h3 class="text-base font-bold text-base-content">{SITE_TITLE}</h3>
          <p class="text-xs text-base-content/50">{SITE_DESCRIPTION}</p>
        </div>
      </div>
      <p class="text-xs text-base-content/40 leading-relaxed">
        Powered by
        <a href="https://github.com/mhya123/Mahiro-Blog" target="_blank" class="text-primary/70 hover:text-primary hover:underline underline-offset-2 transition-colors">Mahiro-Blog</a>
      </p>
      <p class="text-xs text-base-content/40 leading-relaxed">
        Built with
        <a href="https://astro.build" target="_blank" class="hover:text-primary transition-colors">Astro</a>,
        <a href="https://tailwindcss.com" target="_blank" class="hover:text-primary transition-colors">Tailwind CSS</a>,
        <a href="https://animejs.com" target="_blank" class="hover:text-primary transition-colors">anime.js</a>,
        <a href="https://daisyui.com" target="_blank" class="hover:text-primary transition-colors">daisyUI</a>
        &
        <a href="https://gsap.com" target="_blank" class="hover:text-primary transition-colors">GSAP</a>
      </p>
      <!-- 站点统计 -->
      <div class="flex items-center gap-3 text-xs text-base-content/40">
        <span class="flex items-center gap-1">
          <Icon name="lucide:file-text" class="w-3 h-3" />
          {totalPosts} 篇文章
        </span>
        <span class="flex items-center gap-1">
          <Icon name="lucide:git-commit-horizontal" class="w-3 h-3" />
          {buildInfo.totalCommits} 次提交
        </span>
      </div>
    </div>

    <!-- 中栏：快速导航 -->
    <div class="flex flex-col gap-2">
      <span class="footer-title text-xs opacity-60 mb-0">导航</span>
      <div class="grid grid-cols-2 gap-x-6 gap-y-1">
        <a href="/" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="lucide:home" class="w-3 h-3 shrink-0" />首页
        </a>
        <a href="/about" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="lucide:user" class="w-3 h-3 shrink-0" />关于
        </a>
        <a href="/friend" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="lucide:users" class="w-3 h-3 shrink-0" />友链
        </a>
        <a href="/project" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="lucide:folder-kanban" class="w-3 h-3 shrink-0" />项目
        </a>
        <a href="/navigation" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="lucide:compass" class="w-3 h-3 shrink-0" />导航
        </a>
        <a href="/rss.xml" class="text-xs text-base-content/50 hover:text-primary transition-colors duration-200 flex items-center gap-1.5 py-0.5">
          <Icon name="ri:rss-line" class="w-3 h-3 shrink-0" />RSS
        </a>
      </div>
    </div>

    <!-- 右栏：社交 + 备案 -->
    <div class="flex flex-col gap-2">
      <span class="footer-title text-xs opacity-60 mb-0">社交</span>
      <div class="flex flex-wrap gap-1">
        {
          USER_FOOTER_SOCIAL_ICONS.map((icon) => {
            let href = icon.href;
            if (
              (icon.svg.includes('mail') ||
                (icon.svg.includes('at-line') && !icon.svg.includes('wechat'))) &&
              !href.startsWith('mailto:')
            ) {
              href = `mailto:${href}`;
            } else if (icon.svg.includes('qq') && /^\d+$/.test(href)) {
              href = `tencent://message/?uin=${href}&Site=&Menu=yes`;
            }
            return (
              <div class="tooltip" data-tip={icon.title}>
                <a href={href} aria-label={icon.ariaLabel} class="btn btn-ghost btn-circle btn-sm text-base-content/50 hover:text-primary hover:bg-primary/10 transition-all duration-300">
                  <Icon name={icon.svg} class="text-lg" />
                </a>
              </div>
            );
          })
        }
        <div class="tooltip" data-tip="RSS Feed">
          <a href="/rss.xml" aria-label="RSS Feed" class="btn btn-ghost btn-circle btn-sm text-base-content/50 hover:text-primary hover:bg-primary/10 transition-all duration-300">
            <Icon name="ri:rss-line" class="text-lg" />
          </a>
        </div>
      </div>

      {/* ICP 和公安备案信息 */}
      {(SITE_ICP || SITE_POLICE_BEIAN) && (
        <div class="mt-1 text-xs flex flex-col gap-0.5 text-base-content/40">
          {SITE_ICP && (
            <a
              href={SITE_ICP_LINK}
              target="_blank"
              rel="noopener"
              class="font-semibold hover:text-primary transition-colors duration-200"
            >
              {SITE_ICP}
            </a>
          )}
          {SITE_POLICE_BEIAN && (
            <a
              href={SITE_POLICE_BEIAN_LINK}
              target="_blank"
              rel="noopener"
              class="font-semibold hover:text-primary transition-colors duration-200 flex items-center gap-1"
            >
              <Icon name="ri:shield-check-line" class="text-xs" />
              {SITE_POLICE_BEIAN}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- 底部分割线 + 版权 -->
  <div class="w-full border-t border-base-content/10 pt-4 mt-2">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-base-content/40">
      <div class="flex items-center gap-1.5 flex-wrap justify-center sm:justify-start">
        <span>&copy; {yearDisplay}</span>
        <a href={USER_SITE} target="_blank" class="font-bold hover:text-primary transition-colors">{USER_NAME}</a>
        <span class="opacity-50 px-1">|</span>
        <div class="tooltip tooltip-top" data-tip="署名-非商业性使用-相同方式共享 4.0 国际">
          <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors flex items-center gap-1">
            <Icon name="ri:creative-commons-line" class="text-sm" />
            <span>CC BY-NC-SA 4.0</span>
          </a>
        </div>
      </div>
      <p class="flex items-center gap-1.5">
        Crafted with <Icon name="lucide:heart" class="w-3 h-3 text-red-500 fill-red-500 animate-pulse inline" /> by {USER_NAME}
      </p>
    </div>
  </div>
</footer>

<!-- 构建信息 -->
<div class="bg-base-100 rounded-2xl shadow-lg mt-4 px-4 py-3">
  <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-base-content/50">
    <div class="flex items-center gap-3 flex-wrap">
      <span class="flex items-center gap-1">
        <Icon name="lucide:hash" class="w-3.5 h-3.5" />
        Build <span class="font-mono font-bold text-base-content/70">#{buildInfo.totalCommits}</span>
      </span>
      <span class="flex items-center gap-1">
        <Icon name="lucide:clock" class="w-3.5 h-3.5" />
        {buildInfo.buildTime}
      </span>
    </div>
    {buildInfo.commitSha && (
      <a
        href={buildInfo.commitUrl}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1 hover:text-primary transition-colors duration-200"
      >
        <Icon name="lucide:git-commit-horizontal" class="w-3.5 h-3.5" />
        <span class="font-mono font-bold">{buildInfo.commitShort}</span>
        <span class="hidden sm:inline max-w-[200px] truncate">{buildInfo.commitMessage}</span>
        <span class="hidden sm:inline">·</span>
        <span class="hidden sm:inline">{dayjs(buildInfo.commitDate).format("MM/DD HH:mm")}</span>
      </a>
    )}
  </div>
</div>
