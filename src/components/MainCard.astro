---
import { t } from "@config";
import { Icon } from "astro-icon/components";
import Card from "@/components/temple/Card.astro";
import { Image } from "astro:assets";
import type { PostData } from "@interfaces/data";

export interface MainCardProps extends PostData {
  infoIcon?: string; // Icon for the info button
  helpText?: string; // Custom help text (defaults to "Learn More")
  textOverlay?: string; // Text to overlay on background when no image
  showTextBackground?: boolean; // Show text background when no image
  headerClass?: string; // Additional classes for the header
  extraClasses?: string; // Additional classes for the whole card
  titleId?: string;
  descriptionId?: string;
}

const {
  title,
  description,
  image,
  infoIcon = "lucide:help-circle",
  helpText = t("label.learnMore"),
  textOverlay,
  showTextBackground = true,
  headerClass = "",
  extraClasses = "",
  titleId,
  descriptionId,
} = Astro.props as MainCardProps;

// Create a more descriptive label for the button
const accessibleHelpText = `${helpText}: ${title}`;
const heroTitleWrapClass = "maincard-hero-title-wrap max-w-[min(94%,52rem)] bg-black/46 backdrop-blur-lg px-3.5 sm:px-5 py-2 sm:py-3 rounded-2xl border border-white/22 shadow-[0_8px_24px_rgba(0,0,0,0.30)]";
const heroTitleClass = "maincard-hero-title text-balance break-words text-[clamp(1.38rem,4.2vw,2.45rem)] leading-[1.22] sm:leading-[1.16] font-extrabold tracking-[0.005em] text-white [text-shadow:0_2px_16px_rgba(0,0,0,0.55)]";
---

<Card class={`overflow-hidden ${extraClasses}`}>
  {
    image ? (
      // With image - show image with overlay title
      <div class="relative">
        <div class="aspect-video w-full overflow-hidden">
          <Image
            src={image}
            alt={title}
            width={1200}
            height={630}
            format="webp"
            loading="eager"
            class="w-full h-full object-cover"
          />
        </div>

        {/* Flex container for Title and Button */}
  <div class="maincard-hero-header absolute bottom-4 left-4 right-4 lg:bottom-6 lg:left-6 lg:right-6 flex items-end justify-between gap-3 sm:gap-4">
          {/* Title */}
          <div class={heroTitleWrapClass}>
            <h1 id={titleId} class={heroTitleClass}>{title}</h1>
          </div>

          {/* Description Button */}
          {description && (
            <div class="flex-shrink-0">
              <div class="dropdown dropdown-top dropdown-end dropdown-hover">
                <label
                  tabindex="0"
                  aria-label={accessibleHelpText}
                  class="maincard-hero-help group btn btn-sm px-2 bg-black/58 backdrop-blur-md hover:bg-black/80 border border-white/30 text-white shadow-lg rounded-full flex items-center gap-0 transition-all duration-300 ease-in-out"
                >
                  <Icon name={infoIcon} class="w-4 h-4 flex-shrink-0" />
                  <span class="w-0 overflow-hidden group-hover:w-20 transition-all duration-300 text-xs whitespace-nowrap">
                    {helpText}
                  </span>
                </label>
                <div
                  tabindex="0"
                  class="dropdown-content z-[1] card w-64 sm:w-80 p-2 shadow-lg bg-black/70 backdrop-blur-md text-white border border-white/20 mb-4"
                  data-state="closed"
                >
                  <div class="card-body p-3">
                    <p id={descriptionId} class="text-sm sm:text-[0.95rem] leading-relaxed">{description}</p>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    ) : textOverlay ? (
      // No image, but with textOverlay - show gradient background with overlay text
      <div class="relative">
        <div class={`aspect-video w-full overflow-hidden bg-gradient-to-br from-base-300 to-base-100 ${headerClass}`}>
          {showTextBackground && textOverlay && (
            <div class="absolute inset-0 w-full h-full error-animation-container">
              <div class="text-9xl md:text-[12rem] font-bold text-primary opacity-20 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
                {textOverlay}
              </div>
            </div>
          )}
        </div>

        {/* Flex container for Title and Button */}
  <div class="maincard-hero-header absolute bottom-4 left-4 right-4 lg:bottom-6 lg:left-6 lg:right-6 flex items-end justify-between gap-3 sm:gap-4">
          {/* Title */}
          <div class={heroTitleWrapClass}>
            <h1 id={titleId} class={heroTitleClass}>{title}</h1>
          </div>

          {/* Description Button */}
          {description && (
            <div class="flex-shrink-0 relative w-8 h-8 z-10">
              <div class="dropdown dropdown-top dropdown-end dropdown-hover absolute right-0 bottom-0">
                <label
                  tabindex="0"
                  aria-label={accessibleHelpText}
                  class="maincard-hero-help group btn btn-sm px-2 bg-black/58 backdrop-blur-md hover:bg-black/80 border border-white/30 text-white shadow-lg rounded-full flex items-center gap-0 transition-all duration-300 ease-in-out"
                >
                  <Icon name={infoIcon} class="w-4 h-4 flex-shrink-0" />
                  <span class="w-0 overflow-hidden group-hover:w-20 transition-all duration-300 text-xs whitespace-nowrap">
                    {helpText}
                  </span>
                </label>
                <div
                  tabindex="0"
                  class="dropdown-content z-[1] card w-64 sm:w-80 p-2 shadow-lg bg-black/70 backdrop-blur-md text-white border border-white/20 mb-4"
                  data-state="closed"
                >
                  <div class="card-body p-3">
                    <p id={descriptionId} class="text-sm sm:text-[0.95rem] leading-relaxed">{description}</p>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    ) : (
      // No image, no textOverlay - show simple title and description at top
      <div class="pt-6 px-6">
        <h1 id={titleId} class="text-balance break-words text-[clamp(1.5rem,3.3vw,2.2rem)] leading-[1.22] sm:leading-[1.18] font-extrabold tracking-[0.005em]">{title}</h1>
        {description && <p id={descriptionId} class="mt-2 text-sm sm:text-[0.95rem] leading-relaxed text-base-content/80">{description}</p>}
      </div>
    )
  }

  <!-- Content section -->
  <div class="p-4 sm:p-6">
    <slot />
  </div>
</Card>

<script>
  import gsap from "gsap";

  document.addEventListener("astro:page-load", () => {
    // Get all info buttons and dropdown contents
    const infoButtons = document.querySelectorAll(".dropdown label");
    const dropdownContents = document.querySelectorAll(".dropdown-content");

    // Add click event listeners
    infoButtons.forEach((button, index) => {
      button.addEventListener("click", () => {
        const content = dropdownContents[index];
        const currentState = content.getAttribute("data-state");

        // Toggle state
        if (currentState === "closed") {
          content.setAttribute("data-state", "open");
          // Add animation classes when opening
          content.classList.add("scale-100", "opacity-100");
          content.classList.remove("scale-90", "opacity-0");
        } else {
          content.setAttribute("data-state", "closed");
          // Remove animation classes when closing
          content.classList.add("scale-90", "opacity-0");
          content.classList.remove("scale-100", "opacity-100");
        }
      });
    });

    // 动画 GSAP 接管
    // 根绝原生 CSS 由于 max-width 变化引发的文本折行跳动（Reflow Tear）
    const heroHeaders = document.querySelectorAll(".maincard-hero-header");
    heroHeaders.forEach((header) => {
      const helpBtn = header.querySelector(".maincard-hero-help");
      const titleWrap = header.querySelector(".maincard-hero-title-wrap");
      const title = header.querySelector(".maincard-hero-title");
      if (!helpBtn || !titleWrap || !title) return;

      helpBtn.addEventListener("mouseenter", () => {
        gsap.to(titleWrap, {
          y: -2,
          backgroundColor: "rgba(0, 0, 0, 0.5)",
          borderColor: "rgba(255, 255, 255, 0.4)",
          duration: 0.5,
          ease: "power3.out",
        });
        gsap.to(title, {
          scale: 0.96,
          x: 1,
          opacity: 0.88,
          duration: 0.8,
          ease: "elastic.out(1.1, 0.75)",
          transformOrigin: "left center"
        });
      });

      helpBtn.addEventListener("mouseleave", () => {
        gsap.to(titleWrap, {
          y: 0,
          backgroundColor: "rgba(0, 0, 0, 0.46)",
          borderColor: "rgba(255, 255, 255, 0.22)",
          duration: 0.4,
          ease: "power2.out",
        });
        gsap.to(title, {
          scale: 1,
          x: 0,
          opacity: 1,
          duration: 0.7,
          ease: "elastic.out(1, 0.85)",
        });
      });
    });
  });
</script>

<style>
  .maincard-hero-header .maincard-hero-title-wrap {
    flex: 1 1 auto;
    min-width: 0;
    /* 去除了所有导致 reflow 重排的动画属性（如 max-width / padding），将其转交由外部 GSAP 接管弹性拉伸 */
  }

  .maincard-hero-header .maincard-hero-title {
    will-change: transform, opacity;
  }
</style>
