---
/**
 * Twikoo comment system
 * https://twikoo.js.org/
 */
interface Props {
  envId: string;
  region?: string;
  lang?: string;
}

const { envId, region = "", lang = "" } = Astro.props;
---

<div class="relative w-full">
  <div id="tcomment-error" class="hidden absolute top-0 left-0 w-full p-4 bg-error/10 border border-error/20 text-error rounded-xl text-center shadow-sm">
    <div class="font-bold mb-1">评论服务加载失败</div>
    <div class="text-sm opacity-80" id="tcomment-error-text">无法连接到评论服务，请检查网络或稍后再试。</div>
  </div>
  <div id="tcomment" class="w-full min-h-[120px]"></div>
</div>

<script is:inline define:vars={{ envId, region, lang }}>
  const twikooWindow = window;
  let twikooObserver;
  let twikooInitializedPath = "";

  document.addEventListener("astro:page-load", () => {
    scheduleTwikooInit();
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleTwikooInit);
  } else {
    scheduleTwikooInit();
  }

  function showTwikooError(message) {
    document.getElementById("tcomment-error")?.classList.remove("hidden");
    const text = document.getElementById("tcomment-error-text");
    if (text) {
      text.innerText = message;
    }
  }

  function loadStyleOnce(id, href, integrity) {
    const existing = document.getElementById(id);
    if (existing) {
      return Promise.resolve();
    }

    return new Promise((resolve, reject) => {
      const link = document.createElement("link");
      link.id = id;
      link.rel = "preload";
      link.as = "style";
      link.href = href;
      link.crossOrigin = "anonymous";
      if (integrity) {
        link.integrity = integrity;
      }
      link.onload = () => {
        link.onload = null;
        link.rel = "stylesheet";
        resolve();
      };
      link.onerror = () => reject(new Error(`Failed to load stylesheet: ${href}`));
      document.head.appendChild(link);
    });
  }

  function loadScriptOnce(id, src, options = {}) {
    const existing = document.getElementById(id);
    if (existing) {
      return existing.dataset.loaded === "true"
        ? Promise.resolve()
        : new Promise((resolve, reject) => {
            existing.addEventListener("load", () => resolve(), { once: true });
            existing.addEventListener("error", () => reject(new Error(`Failed to load script: ${src}`)), { once: true });
          });
    }

    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.id = id;
      script.src = src;
      script.async = true;
      script.defer = true;
      if (options.integrity) {
        script.integrity = options.integrity;
      }
      if (options.crossorigin) {
        script.crossOrigin = options.crossorigin;
      }
      script.addEventListener("load", () => {
        script.dataset.loaded = "true";
        resolve();
      }, { once: true });
      script.addEventListener("error", () => reject(new Error(`Failed to load script: ${src}`)), { once: true });
      document.head.appendChild(script);
    });
  }

  async function ensureTwikooAssets() {
    await loadStyleOnce(
      "twikoo-katex-style",
      "https://cdn.jsdmirror.com/npm/katex@0.12.0/dist/katex.min.css",
      "sha384-AfEj0r4/OFrOo5t7NnNe46zW/tFgW6x/bCJG8FqQCEo3+Aro6EYUG4+cU+KJWu/X",
    );
    await loadScriptOnce(
      "twikoo-katex-script",
      "https://cdn.jsdmirror.com/npm/katex@0.12.0/dist/katex.min.js",
      {
        integrity: "sha384-g7c+Jr9ZivxKLnZTDUhnkOnsh30B4H0rpLUpJ4jAIKs4fnJI+sEnkvrMWph2EDg4",
        crossorigin: "anonymous",
      },
    );
    await loadScriptOnce(
      "twikoo-katex-render-script",
      "https://cdn.jsdmirror.com/npm/katex@0.12.0/dist/contrib/auto-render.min.js",
      {
        integrity: "sha384-mll67QQFJfxn0IYznZYonOWZ644AWYC+Pt2cHqMaRhXVrursRwvLnLaebdGIlYNa",
        crossorigin: "anonymous",
      },
    );
    await loadScriptOnce(
      "twikoo-core-script",
      "https://s.mahiro.work/d/twikoo.min.js?sign=QiLndPJgjjFbsqK6BAwmmRiNDTv_Fc4Y0CeRTrkem2A=:0",
    );
  }

  function scheduleTwikooInit() {
    const container = document.getElementById("tcomment");
    if (!container) return;

    if (twikooObserver) {
      twikooObserver.disconnect();
    }

    if ("IntersectionObserver" in window) {
      twikooObserver = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        twikooObserver.disconnect();
        initTwikoo();
      }, {
        rootMargin: "320px 0px",
      });

      twikooObserver.observe(container);
      return;
    }

    initTwikoo();
  }

  async function initTwikoo() {
    const currentPath = window.location.pathname;
    if (twikooInitializedPath === currentPath && twikooWindow.twikoo) {
      return;
    }

    try {
      await ensureTwikooAssets();
    } catch (error) {
      console.error("[Twikoo] asset load failed:", error);
      showTwikooError("评论系统核心库加载失败");
      return;
    }

    if (!twikooWindow.twikoo) {
      window.setTimeout(() => {
        if (!twikooWindow.twikoo) {
          showTwikooError("评论系统核心库未正常响应");
        }
      }, 5000);
      return;
    }

    const config = {
      envId,
      el: "#tcomment",
      path: currentPath,
    };

    if (region) config.region = region;
    if (lang) config.lang = lang;

    try {
      const initPromise = twikooWindow.twikoo.init(config);
      twikooInitializedPath = currentPath;

      if (initPromise && typeof initPromise.catch === "function") {
        initPromise.catch((error) => {
          console.error("[Twikoo] init failed:", error);
          showTwikooError(error?.message || "环境 API 初始化或通信失败");
        });
      }
    } catch (error) {
      console.error("[Twikoo] init crashed:", error);
      showTwikooError("发生内部组件异常");
    }
  }
</script>

<style is:global>
  .twikoo .tk-comments {
    color: inherit;
    font-family: inherit;
    width: 100%;
  }

  .twikoo .tk-comments .tk-meta-input {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .twikoo .tk-comments .tk-meta-input .el-input {
    flex: 1;
    width: 100% !important;
    display: flex;
  }

  @media (max-width: 640px) {
    .twikoo .tk-comments .tk-meta-input {
      flex-wrap: wrap;
    }

    .twikoo .tk-comments .tk-meta-input .el-input {
      min-width: 100%;
    }
  }

  /* Prepend styling to match dark/glass theme */
  .twikoo .tk-comments .el-input-group__append,
  .twikoo .tk-comments .el-input-group__prepend {
    background-color: rgba(128, 128, 128, 0.15) !important;
    border: 1px solid rgba(128, 128, 128, 0.1) !important;
    border-right: none !important;
    color: inherit !important;
    border-radius: 0.5rem 0 0 0.5rem !important;
    padding: 0 1rem !important;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Inner inputs and textareas */
  .twikoo .tk-comments .el-input__inner,
  .twikoo .tk-comments .el-textarea__inner,
  .twikoo .tk-comments .tk-input textarea,
  .twikoo .tk-comments .tk-input input {
    background-color: rgba(128, 128, 128, 0.1) !important;
    border: 1px solid rgba(128, 128, 128, 0.1) !important;
    color: inherit !important;
    border-radius: 0.5rem !important; /* Default for inputs without prepend */
    padding: 0.75rem 1rem !important;
    box-shadow: none !important;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  /* Adjust border-radius for inputs with prepend so they connect smoothly */
  .twikoo .tk-comments .el-input-group > .el-input__inner {
    border-radius: 0 0.5rem 0.5rem 0 !important;
  }

  .twikoo .tk-comments .tk-input textarea {
    min-height: 120px !important;
    margin-top: 0.75rem;
  }

  /* Focus states */
  .twikoo .tk-comments .el-input__inner:focus,
  .twikoo .tk-comments .el-textarea__inner:focus,
  .twikoo .tk-comments .tk-input textarea:focus,
  .twikoo .tk-comments .tk-input input:focus {
    border-color: rgba(128, 128, 128, 0.4) !important;
    background-color: rgba(128, 128, 128, 0.15) !important;
    outline: none !important;
  }

  .twikoo .tk-comments .tk-action-icon {
    fill: rgba(128, 128, 128, 0.8) !important;
  }

  .twikoo .tk-action-icon:hover {
    fill: currentColor !important;
  }

  /* Submit button matching global primary theme */
  .twikoo .el-button--primary {
    background-color: oklch(var(--p)) !important;
    border-color: transparent !important;
    color: oklch(var(--pc)) !important;
    border-radius: 0.5rem !important;
    padding: 0 1.5rem !important;
    transition: opacity 0.3s ease;
  }

  .twikoo .el-button--primary:hover {
    opacity: 0.8;
  }

  /* Other buttons */
  .twikoo .el-button:not(.el-button--primary) {
    background-color: rgba(128, 128, 128, 0.15) !important;
    border-color: transparent !important;
    color: inherit !important;
    border-radius: 0.5rem !important;
    padding: 0 1.5rem !important;
    transition: background-color 0.3s ease;
  }

  .twikoo .el-button:not(.el-button--primary):hover {
    background-color: rgba(128, 128, 128, 0.25) !important;
  }
  
  .twikoo .tk-submit {
    padding-top: 0.5rem;
  }

  /* Reset transparent backgrounds that conflict */
  .twikoo,
  .twikoo .tk-comments,
  .twikoo .tk-comment,
  .twikoo .tk-comment:hover,
  .twikoo .tk-replies,
  .twikoo .tk-replies .tk-comment,
  .twikoo .tk-replies .tk-comment:hover,
  .twikoo .tk-meta-input,
  .twikoo .tk-row,
  .twikoo .tk-col {
    background-color: transparent !important;
  }

  .twikoo .tk-avatar {
    margin-right: 1rem !important;
  }

  .twikoo .tk-avatar .tk-avatar-img,
  .twikoo .tk-avatar svg {
    width: 2.5rem !important;
    height: 2.5rem !important;
    border-radius: 50% !important;
  }

  .twikoo .tk-icon,
  .twikoo .tk-action-icon svg,
  .twikoo .tk-action-icon,
  .twikoo svg {
    width: 1.25em;
    height: 1.25em;
    display: inline-block;
  }

  .twikoo .tk-action {
    opacity: 1 !important;
  }
</style>
