---
// Props interface
interface Props {
  serverURL: string;
  lang?: string;
  dark?: string;
  emoji?: string[];
  meta?: string[];
  requiredMeta?: string[];
  reaction?: boolean;
  pageview?: boolean;
}

const {
  serverURL,
  lang = "en",
  dark = "html[data-theme-type='dark']",
  emoji = ["https://unpkg.com/@waline/emojis@1.1.0/weibo", "https://unpkg.com/@waline/emojis@1.1.0/bilibili"],
  meta = ["nick", "mail", "link"],
  requiredMeta = [],
  reaction = false,
  pageview = false,
} = Astro.props;
---

<div id="waline-container"></div>

<script
  type="module"
  is:inline
  define:vars={{
    serverURL,
    lang,
    dark,
    emoji,
    meta,
    requiredMeta,
    reaction,
    pageview,
  }}
>
  let walineInstance;
  let mountedPath = "";

  function ensureWalineStyles() {
    const styleId = "waline-external-style";
    if (document.getElementById(styleId)) {
      return Promise.resolve();
    }

    return new Promise((resolve, reject) => {
      const link = document.createElement("link");
      link.id = styleId;
      link.rel = "preload";
      link.as = "style";
      link.href = "https://unpkg.com/@waline/client@v3/dist/waline.css";
      link.onload = () => {
        link.onload = null;
        link.rel = "stylesheet";
        resolve();
      };
      link.onerror = () => reject(new Error("Failed to load Waline stylesheet"));
      document.head.appendChild(link);
    });
  }

  function loadWalineClient() {
    if (!window.__mahiroWalineClientPromise) {
      window.__mahiroWalineClientPromise = import("https://unpkg.com/@waline/client@v3/dist/waline.js");
    }

    return window.__mahiroWalineClientPromise;
  }

  async function mountWaline() {
    const container = document.getElementById("waline-container");
    if (!container) return;

    const currentPath = location.pathname;
    if (walineInstance && mountedPath === currentPath) {
      return;
    }

    if (walineInstance) {
      await walineInstance.destroy();
      walineInstance = null;
    }

    await ensureWalineStyles();
    const { init } = await loadWalineClient();

    walineInstance = init({
      el: "#waline-container",
      serverURL,
      path: currentPath,
      lang,
      dark,
      emoji,
      meta,
      requiredMeta,
      reaction,
      pageview,
    });
    mountedPath = currentPath;
  }

  function scheduleWalineMount() {
    const container = document.getElementById("waline-container");
    if (!container) return;

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        observer.disconnect();
        mountWaline().catch((error) => {
          console.error("[Waline] failed to mount:", error);
        });
      }, {
        rootMargin: "240px 0px",
      });

      observer.observe(container);
      return;
    }

    mountWaline().catch((error) => {
      console.error("[Waline] failed to mount:", error);
    });
  }

  document.addEventListener("astro:after-swap", () => {
    scheduleWalineMount();
  });

  document.addEventListener("DOMContentLoaded", () => {
    scheduleWalineMount();
  });
</script>

<style>
  #waline-container {
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>
