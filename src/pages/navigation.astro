---
import BaseLayout from "@layouts/BaseLayout.astro";
import NavigationCard from "@components/mdx/NavigationCard.astro";
import { Icon } from "astro-icon/components";
import { NAV_DATA } from "../data/navData";

// 扁平化所有数据以供搜索和"全部"分类使用
const allItems = NAV_DATA.flatMap(category => category.items);

// 导航资源 PR 申请链接（跳转到分类文件夹，用户自由选择要编辑的分类 JSON）
const applyUrl = `https://github.com/mhya123/Mahiro-Blog/tree/main/src/data/navigation`;

const issueTemplate = `### 导航资源收录申请

请严格按照下方 JSON 格式填写资源信息（不需要修改反引号）：

#### 方式一：往已有分类添加资源（推荐）
请说明要添加到哪个分类（如"开发工具"、"AI 工具"、"设计创意"、"在线服务"、"学习资源"、"效率办公"等），并在该分类的 \`items\` 数组末尾追加：
\`\`\`json
{
  "name": "资源名称",
  "avatar": "https://资源图标URL",
  "description": "资源简短描述",
  "url": "https://资源链接",
  "category": "子分类标签"
}
\`\`\`

#### 方式二：新增一整个分类（仅在现有分类不适合时使用）
\`\`\`json
{
  "title": "分类名称",
  "icon": "lucide:图标名",
  "items": [
    {
      "name": "资源名称",
      "avatar": "https://资源图标URL",
      "description": "资源简短描述",
      "url": "https://资源链接",
      "category": "子分类标签",
      "id": "XXX001"
    }
  ]
}
\`\`\`
`;
const issueUrl = `https://github.com/mhya123/Mahiro-Blog/issues/new?title=${encodeURIComponent("导航收录: 资源名称")}&body=${encodeURIComponent(issueTemplate)}`;
---

<BaseLayout title="导航" isIndexed={false}>
  <div class="nav-container min-h-screen bg-base-200/30 -mt-8 pt-8 pb-20 px-4 sm:px-6 lg:px-8 transition-colors duration-300">
    <div class="max-w-7xl mx-auto space-y-10">
      
      <!-- 顶部搜索区域 -->
      <div class="relative max-w-2xl mx-auto mt-10">
        <div class="relative group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <Icon name="lucide:search" class="h-5 w-5 text-base-content/40 group-focus-within:text-primary transition-colors" />
          </div>
          <input
            type="text"
            id="search-input"
            class="block w-full pl-11 pr-12 py-4 bg-base-100 border-none rounded-3xl text-base-content placeholder-base-content/40 focus:ring-2 focus:ring-primary/50 focus:bg-base-100 shadow-sm transition-all duration-300"
            placeholder="搜索资源名称、描述..."
          />
          <!-- 清除按钮 -->
          <button
            id="search-clear"
            class="absolute inset-y-0 right-0 pr-4 flex items-center opacity-0 pointer-events-none transition-all duration-200"
            aria-label="清除搜索"
          >
            <Icon name="lucide:x-circle" class="h-5 w-5 text-base-content/40 hover:text-primary transition-colors" />
          </button>
        </div>
        <!-- 搜索状态提示条 -->
        <div id="search-status" class="mt-3 text-center text-sm text-base-content/50 transition-all duration-300 h-0 overflow-hidden opacity-0">
        </div>
      </div>

      <!-- 分类标签栏 -->
      <div class="flex flex-wrap justify-center gap-3" id="category-filters">
        <button
          class="category-btn active px-6 py-2 rounded-full text-sm font-bold transition-all duration-300 bg-primary text-primary-content shadow-md hover:shadow-lg hover:-translate-y-0.5"
          data-category="all"
        >
          <span class="btn-label">全部</span>
          <span class="count-badge ml-1.5 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 text-xs rounded-full bg-primary-content/20 text-primary-content font-bold transition-all duration-300">{allItems.length}</span>
        </button>
        {NAV_DATA.map((category) => (
          <button
            class="category-btn px-6 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-base-100 text-base-content/60 hover:bg-base-200 hover:text-primary hover:shadow-md hover:-translate-y-0.5"
            data-category={category.title}
          >
            <span class="btn-label">{category.title}</span>
            <span class="count-badge ml-1.5 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 text-xs rounded-full bg-primary/15 text-primary font-bold transition-all duration-300">{category.items.length}</span>
          </button>
        ))}
      </div>

      <!-- 资源网格 -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="resources-grid">
        {NAV_DATA.flatMap(category => 
          category.items.map(item => ({ ...item, parentCategory: category.title }))
        ).map((item) => (
          <div 
            class="resource-item" 
            data-category={item.category} 
            data-parent-category={item.parentCategory}
            data-name={item.name.toLowerCase()} 
            data-desc={item.description.toLowerCase()}
            data-url={new URL(item.url).hostname.toLowerCase()}
          >
            <NavigationCard {...item} />
          </div>
        ))}
      </div>

      <!-- 无结果提示 -->
      <div id="no-results" class="hidden text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 dark:bg-base-200 mb-4">
          <Icon name="lucide:search-x" class="w-8 h-8 text-gray-400" />
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">未找到相关资源</h3>
        <p class="mt-2 text-gray-500 dark:text-gray-400">请尝试更换关键词或分类</p>
      </div>

      <div class="divider my-6 onload-animation" data-stagger-index="0">
        <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
      </div>

      <!-- 导航资源提交区块 -->
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-4 flex items-center gap-3">
          <Icon name="lucide:plus-circle" class="text-primary" />
          <span>提交资源</span>
        </h2>
        <p class="text-base-content/70 text-base mb-6">
          发现了好用的工具或网站？欢迎通过 GitHub PR 提交，机器人会自动审核并合并！
        </p>

        <div class="bg-base-100 rounded-2xl border border-base-200 p-6 md:p-8 mb-6">
          <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
            <Icon name="lucide:info" class="w-5 h-5 text-primary" />
            收录要求
          </h3>
          <ul class="space-y-3 text-base-content/80 text-sm">
            <li class="flex items-start gap-2">
              <Icon name="lucide:check-circle" class="w-4 h-4 text-green-500 mt-0.5 shrink-0" />
              <span>资源链接能够正常访问</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="lucide:check-circle" class="w-4 h-4 text-green-500 mt-0.5 shrink-0" />
              <span>资源有实际使用价值（非钓鱼/广告站）</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="lucide:check-circle" class="w-4 h-4 text-green-500 mt-0.5 shrink-0" />
              <span>不包含违规/恶意/侵权内容</span>
            </li>
            <li class="flex items-start gap-2">
              <Icon name="lucide:check-circle" class="w-4 h-4 text-green-500 mt-0.5 shrink-0" />
              <span>提供有效的图标 URL</span>
            </li>
          </ul>

          <div class="divider my-4"></div>

          <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
            <Icon name="lucide:file-json" class="w-5 h-5 text-primary" />
            JSON 格式（往已有分类添加资源）
          </h3>
          <p class="text-sm text-base-content/60 mb-3">
            选择一个已有的分类文件（如 <code>dev-tools.json</code>、<code>ai-tools.json</code> 等），在其 <code>items</code> 数组末尾追加一项：
          </p>
          <div class="bg-base-200/50 rounded-xl p-4 font-mono text-sm overflow-x-auto">
            <pre class="whitespace-pre text-base-content/80">{JSON.stringify({
  name: "资源名称",
  avatar: "https://资源图标URL",
  description: "资源简短描述",
  url: "https://资源链接",
  category: "子分类标签"
}, null, 2)}</pre>
          </div>
        </div>

        <!-- 提示 -->
        <div class="alert alert-warning mb-4 flex items-center gap-2 text-sm">
          <Icon name="lucide:alert-triangle" class="w-5 h-5 shrink-0" />
          <span><strong>操作说明：</strong> 点击按钮后会进入分类文件夹，选择对应的分类 JSON 文件（如 <code>dev-tools.json</code>、<code>ai-tools.json</code> 等），点击编辑按钮，在 <code>items</code> 数组末尾追加您的资源，然后提交 PR 即可。</span>
        </div>

        <!-- Issue 备用通道 -->
        <div class="alert alert-info mb-6 flex items-start gap-2 text-sm">
          <Icon name="lucide:info" class="w-5 h-5 shrink-0 mt-0.5" />
          <div>
            <strong>不熟悉 PR？</strong>
            <p class="mt-1">也可以通过 <a href={issueUrl} target="_blank" rel="noopener noreferrer" class="link font-bold">提交 Issue</a> 来申请收录，管理员会人工审核处理。</p>
          </div>
        </div>

        <!-- 申请按钮 -->
        <div class="flex justify-center">
          <a
            href={applyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg gap-2 px-8 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 press-effect btn-shine-effect"
          >
            <Icon name="lucide:folder-open" class="w-5 h-5" />
            前往 GitHub 选择分类并提交
          </a>
        </div>
      </div>

      <div class="divider my-6">
        <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
      </div>

    </div>
  </div>
</BaseLayout>

<!-- 把 navData 注入到 window，供模块化脚本读取 -->
<script is:inline define:vars={{ navData: NAV_DATA }}>
  window.__NAV_DATA = navData;
</script>

<!-- anime.js 驱动的搜索与分类过滤 -->
<script>
  import { animate, stagger } from 'animejs';

  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const searchClear = document.getElementById('search-clear') as HTMLElement | null;
    const searchStatus = document.getElementById('search-status') as HTMLElement | null;
    const categoryBtns = document.querySelectorAll<HTMLElement>('.category-btn');
    const resourceItems = document.querySelectorAll<HTMLElement>('.resource-item');
    const noResults = document.getElementById('no-results');
    const grid = document.getElementById('resources-grid');
    if (!grid) return;

    let currentCategory = 'all';
    let currentSearch = '';

    // ─── 预计算数据索引（避免反复读 DOM dataset）──────
    interface ItemData {
      el: HTMLElement;
      name: string;
      desc: string;
      url: string;
      parentCategory: string;
      nameEl: Element | null;
      descEl: Element | null;
      urlEl: Element | null;
      nameOriginal: string;
      descOriginal: string;
      urlOriginal: string;
      visible: boolean;
    }

    const itemsData: ItemData[] = Array.from(resourceItems).map(el => {
      const nameEl = el.querySelector('h3');
      const descEl = el.querySelector('p');
      const urlEl = el.querySelector('.font-mono');
      return {
        el,
        name: (el.dataset.name || ''),
        desc: (el.dataset.desc || ''),
        url: (el.dataset.url || ''),
        parentCategory: (el.dataset.parentCategory || ''),
        nameEl,
        descEl,
        urlEl,
        nameOriginal: nameEl?.textContent || '',
        descOriginal: descEl?.textContent || '',
        urlOriginal: urlEl?.textContent || '',
        visible: true,
      };
    });

    // ─── 高亮工具（轻量化）─────────────────────────────
    function escapeRegExp(str: string) {
      return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function applyHighlight(target: Element | null, original: string, keyword: string) {
      if (!target || !keyword) return;
      const regex = new RegExp(`(${escapeRegExp(keyword)})`, 'gi');
      if (regex.test(original)) {
        target.innerHTML = original.replace(regex, '<mark class="nav-highlight bg-primary/25 text-primary font-bold rounded px-0.5">$1</mark>');
      } else if (target.innerHTML !== original) {
        target.textContent = original;
      }
    }

    function clearItemHighlight(d: ItemData) {
      if (d.nameEl && d.nameEl.innerHTML !== d.nameOriginal) d.nameEl.textContent = d.nameOriginal;
      if (d.descEl && d.descEl.innerHTML !== d.descOriginal) d.descEl.textContent = d.descOriginal;
      if (d.urlEl && d.urlEl.innerHTML !== d.urlOriginal) d.urlEl.textContent = d.urlOriginal;
    }

    function highlightItem(d: ItemData, keyword: string) {
      if (!keyword) { clearItemHighlight(d); return; }
      applyHighlight(d.nameEl, d.nameOriginal, keyword);
      applyHighlight(d.descEl, d.descOriginal, keyword);
      applyHighlight(d.urlEl, d.urlOriginal, keyword);
    }

    // ─── 匹配判断 ──────────────────────────────────────
    // ─── 更新 UI 辅助 ──────────────────────────────────
    function updateSearchStatus(visibleCount: number, keyword: string) {
      if (!searchStatus) return;
      if (keyword) {
        searchStatus.innerHTML = `找到 <strong class="text-primary">${visibleCount}</strong> 个匹配「<strong class="text-primary">${keyword}</strong>」的资源`;
        searchStatus.style.height = '1.5rem';
        searchStatus.style.opacity = '1';
      } else {
        searchStatus.style.height = '0';
        searchStatus.style.opacity = '0';
      }
    }

    function updateClearButton(show: boolean) {
      if (!searchClear) return;
      searchClear.style.opacity = show ? '1' : '0';
      searchClear.style.pointerEvents = show ? 'auto' : 'none';
    }

    function updateCategoryBadges(countMap: Map<string, number>) {
      categoryBtns.forEach(btn => {
        const cat = btn.dataset.category || 'all';
        const badge = btn.querySelector('.count-badge') as HTMLElement | null;
        if (!badge) return;

        const count = countMap.get(cat) ?? 0;
        badge.textContent = String(count);
        badge.classList.toggle('!opacity-40', currentSearch !== '' && count === 0);
      });
    }

    // ─── 核心 filter：一次遍历计算所有数据，无阻塞 ─────
    // 用 requestAnimationFrame 确保不阻塞后续点击

    let pendingFilter: number | null = null;
    let runningAnimation: { cancel: () => void } | null = null;

    function scheduleFilter() {
      if (pendingFilter !== null) cancelAnimationFrame(pendingFilter);
      pendingFilter = requestAnimationFrame(() => {
        pendingFilter = null;
        executeFilter();
      });
    }

    function executeFilter() {
      // 取消上一轮未完成的动画
      if (runningAnimation) {
        runningAnimation.cancel();
        runningAnimation = null;
      }

      const toHide: HTMLElement[] = [];
      const toShow: HTMLElement[] = [];
      const stayVisible: ItemData[] = [];

      // 一次遍历，同时计算分类计数
      const countMap = new Map<string, number>();
      countMap.set('all', 0);
      categoryBtns.forEach(btn => {
        const cat = btn.dataset.category || '';
        if (cat !== 'all') countMap.set(cat, 0);
      });

      for (const d of itemsData) {
        // 计算该 item 在"每个分类 + 当前搜索词"下是否匹配
        const matchSearch = !currentSearch || d.name.includes(currentSearch) || d.desc.includes(currentSearch) || d.url.includes(currentSearch);
        
        if (matchSearch) {
          countMap.set('all', (countMap.get('all') ?? 0) + 1);
          const pc = d.parentCategory;
          if (countMap.has(pc)) countMap.set(pc, (countMap.get(pc) ?? 0) + 1);
        }

        const shouldShow = matchSearch && (currentCategory === 'all' || d.parentCategory === currentCategory);

        if (shouldShow && !d.visible) {
          toShow.push(d.el);
          d.visible = true;
        } else if (!shouldShow && d.visible) {
          toHide.push(d.el);
          d.visible = false;
        } else if (shouldShow) {
          stayVisible.push(d);
        }
      }

      // 更新已可见卡片的高亮
      for (const d of stayVisible) {
        highlightItem(d, currentSearch);
      }

      // 更新 badge & 状态栏（不等动画）
      updateCategoryBadges(countMap);
      const totalVisible = toShow.length + stayVisible.length;
      updateSearchStatus(totalVisible, currentSearch);

      // noResults
      if (noResults) {
        noResults.style.display = totalVisible === 0 ? 'block' : 'none';
      }

      // ─── 动画部分 ────────────────────────────────────
      let cancelled = false;
      runningAnimation = {
        cancel() {
          cancelled = true;
          // 立即完成所有挂起的元素状态
          toHide.forEach(el => { el.style.display = 'none'; el.style.opacity = ''; el.style.transform = ''; });
          toShow.forEach(el => { el.style.display = ''; el.style.opacity = '1'; el.style.transform = ''; });
          // 下一帧清除内联样式，让 CSS 接管
          requestAnimationFrame(() => {
            toShow.forEach(el => { el.style.opacity = ''; });
          });
        }
      };

      // 隐藏元素：柔和淡出
      if (toHide.length > 0) {
        animate(toHide, {
          opacity: [1, 0],
          scale: [1, 0.92],
          translateY: ['0px', '8px'],
          duration: 200,
          ease: 'in(1.5)',
          onComplete() {
            if (cancelled) return;
            toHide.forEach(el => {
              el.style.display = 'none';
              el.style.opacity = '';
              el.style.transform = '';
            });
            // 清除隐藏项的高亮
            for (const d of itemsData) {
              if (!d.visible) clearItemHighlight(d);
            }
          }
        });
      }

      // 显示元素：弹性入场
      if (toShow.length > 0) {
        toShow.forEach(el => {
          el.style.display = '';
          el.style.opacity = '0';
          el.style.transform = 'translateY(24px) scale(0.9)';
        });
        // 设置高亮
        for (const d of itemsData) {
          if (toShow.includes(d.el)) highlightItem(d, currentSearch);
        }

        animate(toShow, {
          opacity: [0, 1],
          scale: [0.9, 1],
          translateY: ['24px', '0px'],
          duration: 500,
          delay: stagger(35, { start: 100 }),
          ease: 'out(1.5, 0.55)',
          onComplete() {
            if (cancelled) return;
            toShow.forEach(el => { el.style.opacity = ''; el.style.transform = ''; });
          }
        });
      }
    }

    // ─── 初始显示所有卡片 ─────────────────────────────
    itemsData.forEach(d => { d.el.style.display = ''; d.visible = true; });

    // ─── 分类按钮点击事件 ─────────────────────────────
    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category || 'all';
        if (cat === currentCategory) return; // 点击已选中的不重复

        // 按钮弹性反馈
        animate(btn, {
          scale: [1, 0.92, 1.06, 1],
          duration: 350,
          ease: 'out(3)',
        });

        // 更新按钮样式
        categoryBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-primary-content', 'font-bold', 'shadow-md');
          b.classList.add('bg-base-100', 'text-base-content/60', 'font-medium');
          const badge = b.querySelector('.count-badge') as HTMLElement | null;
          if (badge) {
            badge.classList.remove('bg-primary-content/20', 'text-primary-content');
            badge.classList.add('bg-primary/15', 'text-primary');
          }
        });
        btn.classList.remove('bg-base-100', 'text-base-content/60', 'font-medium');
        btn.classList.add('bg-primary', 'text-primary-content', 'font-bold', 'shadow-md');
        const activeBadge = btn.querySelector('.count-badge') as HTMLElement | null;
        if (activeBadge) {
          activeBadge.classList.remove('bg-primary/15', 'text-primary');
          activeBadge.classList.add('bg-primary-content/20', 'text-primary-content');
        }

        currentCategory = cat;
        scheduleFilter();
      });
    });

    // ─── 搜索输入事件 (debounce) ──────────────────────
    let searchTimer: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchTimer);
      const value = (e.target as HTMLInputElement).value;
      updateClearButton(value.length > 0);
      searchTimer = setTimeout(() => {
        currentSearch = value.toLowerCase();
        scheduleFilter();
      }, 150);
    });

    // ─── 清除按钮 ────────────────────────────────────
    searchClear?.addEventListener('click', () => {
      if (!searchInput) return;
      searchInput.value = '';
      searchInput.focus();
      updateClearButton(false);
      currentSearch = '';
      scheduleFilter();
    });

    // ─── ESC 键清除搜索 ──────────────────────────────
    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        updateClearButton(false);
        currentSearch = '';
        scheduleFilter();
        searchInput.blur();
      }
    });
  });
</script>

