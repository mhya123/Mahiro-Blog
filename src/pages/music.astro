---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MusicPlayer from "@/components/widgets/MusicPlayer.astro";
import { getAllPlaylists } from "@/data/music";

const playlists = await getAllPlaylists();
const allSongs = playlists.flatMap(p => p.songs);
const playlistsJson = JSON.stringify(playlists);
---

<BaseLayout title="音乐" showSidebar={false} showTOC={false} isIndexed={false}>
    <div class="max-w-5xl mx-auto py-8 px-4 space-y-8">

    <!-- 使用说明 -->
    <div class="music-guide rounded-2xl border border-base-200 bg-base-100 shadow-sm overflow-hidden">
      <button id="guide-toggle" class="w-full flex items-center gap-2 cursor-pointer p-4 select-none hover:bg-base-200/50 transition-colors text-left">
        <svg id="guide-info-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        <span class="font-bold text-base-content">音乐模块使用说明</span>
        <svg id="guide-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto text-base-content/40"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div id="guide-body" class="overflow-hidden" style="height: 0;">
        <div class="px-4 pb-5 pt-1 text-sm text-base-content/70 space-y-4 border-t border-base-200">
        
        <div class="guide-step">
          <h4 class="font-bold text-base-content mb-1.5 flex items-center gap-1.5">
            <span class="text-primary">①</span> 歌单导入（网易云）
          </h4>
          <p>编辑 <code class="px-1.5 py-0.5 rounded bg-base-200 text-xs font-mono">src/data/music-ids.json</code>，添加网易云歌单：</p>
          <pre class="mt-2 p-3 rounded-xl bg-base-200/70 text-xs font-mono overflow-x-auto"><code>{`{
  "playlists": [
    {
      "name": "我的歌单",
      "type": "netease-playlist",
      "neteaseId": 你的歌单ID,
      "cover": ""
    }
  ]
}`}</code></pre>
          <p class="mt-1.5 text-xs text-base-content/50">💡 歌单 ID 可从网易云音乐歌单链接中获取，如 <code class="px-1 py-0.5 rounded bg-base-200 font-mono">music.163.com/playlist?id=<b>123456</b></code></p>
        </div>

        <div class="guide-step">
          <h4 class="font-bold text-base-content mb-1.5 flex items-center gap-1.5">
            <span class="text-primary">②</span> 手动添加歌曲
          </h4>
          <p>编辑 <code class="px-1.5 py-0.5 rounded bg-base-200 text-xs font-mono">src/data/music.json</code>，直接填写歌曲信息：</p>
          <pre class="mt-2 p-3 rounded-xl bg-base-200/70 text-xs font-mono overflow-x-auto"><code>{`[
  {
    "title": "歌曲名",
    "artist": "歌手",
    "cover": "封面图URL",
    "url": "音频URL",
    "lrc": "歌词URL（可选）"
  }
]`}</code></pre>
          <p class="mt-1.5 text-xs text-base-content/50">💡 此文件中的歌曲会作为「本地歌单」显示</p>
        </div>

        <div class="guide-step">
          <h4 class="font-bold text-base-content mb-1.5 flex items-center gap-1.5">
            <span class="text-primary">③</span> API 配置
          </h4>
          <p>在 <code class="px-1.5 py-0.5 rounded bg-base-200 text-xs font-mono">mahiro.config.yaml</code> 中配置 Meting API 地址：</p>
          <pre class="mt-2 p-3 rounded-xl bg-base-200/70 text-xs font-mono overflow-x-auto"><code>{`music:
  api: https://api.qijieya.cn/meting  # Meting API 地址
  autoplay: false                      # 是否自动播放`}</code></pre>
        </div>

        <div class="guide-step flex items-start gap-2 p-3 rounded-xl bg-primary/5 border border-primary/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary shrink-0 mt-0.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <div class="text-xs space-y-1">
            <p><b>播放器功能：</b>支持歌单切换、随机/顺序/单曲循环、歌词同步显示、音量控制、进度拖拽。</p>
            <p><b>状态记忆：</b>播放进度、音量、播放模式、当前歌单会自动保存，刷新页面后恢复。</p>
            <p><b>全局迷你播放器：</b>离开音乐页面后，左下角会出现迷你播放器悬浮按钮，支持悬停展开控制。</p>
          </div>
        </div>
        </div>
      </div>
    </div>

    <!-- 歌单列表 -->
    <div id="playlist-selector">
      <h2 class="text-2xl font-bold text-base-content mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15V6"/><path d="M18.5 18a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path d="M12 12H3"/><path d="M16 6H3"/><path d="M12 18H3"/></svg>
        歌单
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {playlists.map((playlist, idx) => (
          <button
            class:list={[
              "playlist-card group relative overflow-hidden rounded-2xl border border-base-200 bg-base-100 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 text-left",
              idx === 0 ? "ring-2 ring-primary active-playlist" : ""
            ]}
            data-playlist-index={idx}
          >
            <!-- 封面 -->
            <div class="aspect-square overflow-hidden bg-base-200">
              {playlist.cover ? (
                <img
                  src={playlist.cover}
                  alt={playlist.name}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-secondary/20">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary/40">
                    <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                  </svg>
                </div>
              )}
            </div>
            <!-- 歌单信息 -->
            <div class="p-3">
              <h3 class="font-bold text-sm text-base-content truncate">{playlist.name}</h3>
              <p class="text-xs text-base-content/50 mt-0.5">{playlist.songs.length} 首歌</p>
            </div>
            <!-- 播放状态指示器 -->
            <div class="absolute top-2 right-2 w-8 h-8 rounded-full bg-primary text-primary-content flex items-center justify-center opacity-0 group-[.active-playlist]:opacity-100 transition-opacity shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </button>
        ))}
      </div>
    </div>

    <!-- 播放器 -->
    <div id="music-player-container">
      <MusicPlayer list={allSongs} />
    </div>
  </div>

  <script>
    import gsap from "gsap";

    document.addEventListener("astro:page-load", () => {

      // ─── 使用说明 GSAP 折叠动画 ───
      const guideToggle = document.getElementById('guide-toggle');
      const guideBody = document.getElementById('guide-body');
      const guideChevron = document.getElementById('guide-chevron');
      const guideInfoIcon = document.getElementById('guide-info-icon');

      if (guideToggle && guideBody) {
        let isOpen = false;
        let isAnimating = false;

        guideToggle.addEventListener('click', () => {
          if (isAnimating) return;
          isAnimating = true;
          isOpen = !isOpen;

          if (isOpen) {
            // 展开：先设置 height auto 获取实际高度，再动画
            guideBody.style.height = 'auto';
            const fullHeight = guideBody.scrollHeight;
            guideBody.style.height = '0px';

            const tl = gsap.timeline({
              onComplete: () => {
                guideBody.style.height = 'auto';
                isAnimating = false;
              }
            });

            // chevron 旋转
            tl.to(guideChevron, {
              rotation: 180,
              duration: 0.4,
              ease: 'back.out(1.7)',
            }, 0);

            // info 图标弹跳
            if (guideInfoIcon) {
              tl.fromTo(guideInfoIcon, { scale: 1 }, {
                scale: 1.2,
                duration: 0.15,
                yoyo: true,
                repeat: 1,
                ease: 'power2.out',
              }, 0);
            }

            // 面板展开
            tl.to(guideBody, {
              height: fullHeight,
              duration: 0.5,
              ease: 'expo.out',
            }, 0);

            // 步骤卡片交错入场
            const steps = guideBody.querySelectorAll('.guide-step');
            tl.fromTo(steps, {
              y: 20,
              opacity: 0,
              scale: 0.97,
            }, {
              y: 0,
              opacity: 1,
              scale: 1,
              duration: 0.45,
              ease: 'power3.out',
              stagger: 0.08,
              clearProps: 'transform',
            }, 0.15);

          } else {
            // 收起
            const tl = gsap.timeline({
              onComplete: () => {
                isAnimating = false;
              }
            });

            // chevron 复位
            tl.to(guideChevron, {
              rotation: 0,
              duration: 0.35,
              ease: 'power2.inOut',
            }, 0);

            // 步骤先淡出
            const steps = guideBody.querySelectorAll('.guide-step');
            tl.to(steps, {
              y: -10,
              opacity: 0,
              duration: 0.2,
              ease: 'power2.in',
              stagger: 0.03,
            }, 0);

            // 面板收起
            tl.to(guideBody, {
              height: 0,
              duration: 0.4,
              ease: 'expo.inOut',
            }, 0.1);
          }
        });
      }
    });
  </script>

  <script is:inline define:vars={{ playlistsJson }}>
    document.addEventListener("astro:page-load", () => {
      const playlists = JSON.parse(playlistsJson);
      const cards = document.querySelectorAll('.playlist-card');

      // ─── 工具函数：生成歌曲列表 HTML ───
      function renderPlaylistItems(songs, activeIndex) {
        const count = Math.min(songs.length, 30);
        return songs.slice(0, count).map((s, i) => `
          <li class="playlist-item group flex items-center gap-3 p-3 rounded-2xl hover:bg-black/5 dark:hover:bg-white/5 border border-transparent transition-all cursor-pointer ${i === activeIndex ? 'active' : ''}" data-index="${i}">
            <span class="font-mono text-neu-text-muted text-sm font-bold w-6 text-center group-hover:text-neu-accent transition-colors">${String(i + 1).padStart(2, '0')}</span>
            <div class="relative w-12 h-12 rounded-lg overflow-hidden shrink-0 border border-neu-border/50">
              <img src="${s.cover || ''}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="cover" loading="lazy"/>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center gap-1">
              <h3 class="font-bold text-neu-text truncate text-sm leading-none group-[.active]:text-neu-accent transition-colors">${s.title || 'Unknown'}</h3>
              <p class="text-[11px] text-neu-text-muted truncate uppercase tracking-wider">${s.artist || 'Unknown'}</p>
            </div>
          </li>
        `).join('');
      }

      // ─── 工具函数：绑定歌曲列表点击 ───
      function bindPlaylistClicks(listEl) {
        listEl.querySelectorAll('.playlist-item').forEach(item => {
          item.addEventListener('click', () => {
            const index = parseInt(item.getAttribute('data-index'));
            if (window.globalMusicPlayer) window.globalMusicPlayer.loadSong(index);
          });
        });
      }

      // ─── 工具函数：将歌单转为播放器格式 ───
      function toPlayerFormat(songs) {
        return songs.map(s => ({
          title: s.title,
          artist: s.artist,
          cover: s.cover,
          url: s.url,
          lrc: s.lrc || '',
        }));
      }

      // ─── 工具函数：更新播放列表 DOM ───
      function syncPlaylistDOM(songs) {
        const widget = document.querySelector('.music-player-widget');
        if (widget) widget.setAttribute('data-playlist', JSON.stringify(songs));

        const playlistList = document.getElementById('playlist-list');
        if (playlistList) {
          playlistList.innerHTML = renderPlaylistItems(songs, window.globalMusicPlayer?.currentIndex ?? -1);
          bindPlaylistClicks(playlistList);
        }

        const container = document.getElementById('playlist-container');
        if (container) {
          const countDiv = container.querySelector('.text-xs.font-mono');
          if (countDiv) countDiv.textContent = `共 ${songs.length} 首`;

          const oldLoadMore = document.getElementById('playlist-load-more');
          if (oldLoadMore) oldLoadMore.remove();

          // 触发 Load More 重建
          setTimeout(() => {
            document.dispatchEvent(new CustomEvent('playlist-changed', { detail: { length: songs.length } }));
          }, 50);
        }
      }

      // ─── 1. 恢复选中歌单 ───
      let activeIdx = 0;
      try {
        // 优先从播放器实例读取，其次从缓存读取
        if (window.globalMusicPlayer && window.globalMusicPlayer._playlistIdx != null) {
          activeIdx = Math.min(window.globalMusicPlayer._playlistIdx, playlists.length - 1);
        } else {
          const raw = localStorage.getItem('mahiro_player_state');
          if (raw) {
            const state = JSON.parse(raw);
            if (state.playlistIdx != null) activeIdx = Math.min(state.playlistIdx, playlists.length - 1);
          }
        }
      } catch(e) {}

      cards.forEach((c, idx) => {
        if (idx === activeIdx) c.classList.add('ring-2', 'ring-primary', 'active-playlist');
        else c.classList.remove('ring-2', 'ring-primary', 'active-playlist');
      });

      // ─── 2. 初始同步播放列表 ───
      const initPlaylist = playlists[activeIdx] || playlists[0];
      if (initPlaylist) {
        const songs = toPlayerFormat(initPlaylist.songs);
        // 同步播放器实例的 playlist（修复刷新后歌单不一致问题）
        if (window.globalMusicPlayer) {
          const player = window.globalMusicPlayer;
          const playlistChanged = player.playlist.length !== songs.length
            || (songs[0] && player.playlist[0]?.url !== songs[0].url);
          if (playlistChanged) {
            player.playlist = songs;
            player._playlistIdx = activeIdx;
            // 修正 currentIndex 不超过新歌单长度
            if (player.currentIndex >= songs.length) player.currentIndex = 0;
            if (player.isShuffle) player.generateShuffleOrder();
            // 重新加载当前歌曲（不自动播放，保持之前的播放状态）
            const wasPlaying = player.isPlaying;
            player.loadSong(player.currentIndex, false);
            if (wasPlaying && player.audio) {
              player.audio.play().catch(() => {});
            }
          }
        }
        syncPlaylistDOM(songs);
      }

      // ─── 3. 歌单卡片点击 ───
      cards.forEach(card => {
        card.addEventListener('click', () => {
          const idx = parseInt(card.getAttribute('data-playlist-index'));
          const playlist = playlists[idx];
          if (!playlist) return;

          // 更新选中态
          cards.forEach(c => c.classList.remove('ring-2', 'ring-primary', 'active-playlist'));
          card.classList.add('ring-2', 'ring-primary', 'active-playlist');

          if (!window.globalMusicPlayer) return;

          const songs = toPlayerFormat(playlist.songs);

          // 更新播放器
          window.globalMusicPlayer.playlist = songs;
          if (window.globalMusicPlayer.isShuffle) window.globalMusicPlayer.generateShuffleOrder();
          window.globalMusicPlayer.currentIndex = 0;
          window.globalMusicPlayer.loadSong(0);

          // 持久化
          window.globalMusicPlayer._playlistIdx = idx;
          window.globalMusicPlayer._collectAndSave(true);

          // 同步 DOM
          syncPlaylistDOM(songs);
        });
      });
    });
  </script>
</BaseLayout>
