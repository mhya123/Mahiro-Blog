---
import type { Post, Page } from "@interfaces/data";
import PostCard from "@components/PostCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import Pagination from "@components/widgets/Pagination.astro";
import CardGroup from "@components/temple/CardGroup.astro";
import Announcement from "@components/sidebar/Announcement.astro";
import { Icon } from "astro-icon/components";
import { t } from "@config";
import { generatePageLinksByCurrent } from "@utils/blogUtils";
import { getMainBlogPaginationPaths } from "@utils/paginationUtils";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getMainBlogPaginationPaths({ paginate });
}

if (typeof Astro !== "undefined" && Astro.request) {
  try {
    const reqPath = new URL(Astro.request.url).pathname;
    if (/\.[^\/]+$/.test(reqPath)) {
      throw new Response(null, { status: 404 });
    }
  } catch (e) {
    // 忽略解析错误，继续正常渲染
  }
}

const { page }: { page: Page } = Astro.props;
const totalPages = Math.ceil(page.total / page.size);
const pageLinks = generatePageLinksByCurrent(totalPages, page.current);
---

<BaseLayout title="Blog" isIndexed={false}>
  <!-- Blog Navigation Cards -->
  <CardGroup cols="3" class="grid-cols-2">
    <!-- Archives Card -->
    <a href="/blog/archives" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="0">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-accent/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:archive" class="w-4 h-4 sm:w-6 sm:h-6 text-accent" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">{t("label.archivePage")}</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">{t("label.archivesPageDescription")}</p>
        </div>
      </div>
    </a>

    <!-- Categories Card -->
    <a href="/blog/categories" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="1">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-primary/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:folder" class="w-4 h-4 sm:w-6 sm:h-6 text-primary" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">{t("label.categoryPage")}</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">{t("label.categoriesPageDescription")}</p>
        </div>
      </div>
    </a>

    <!-- Tags Card -->
    <a href="/blog/tags" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="2">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-secondary/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:tag" class="w-4 h-4 sm:w-6 sm:h-6 text-secondary" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">{t("label.tagPage")}</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">{t("label.tagsPageDescription")}</p>
        </div>
      </div>
    </a>

    <!-- Search Card -->
    <a href="/blog/search" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="3">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-info/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:search" class="w-4 h-4 sm:w-6 sm:h-6 text-info" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">{t("label.searchPage")}</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">{t("label.searchPageDescription")}</p>
        </div>
      </div>
    </a>

    <!-- Drive Card -->
    <a href="/drive" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="4">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-success/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:hard-drive" class="w-4 h-4 sm:w-6 sm:h-6 text-success" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">网盘</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">站内文件浏览、预览与下载</p>
        </div>
      </div>
    </a>

    <!-- Write Card -->
    <a href="/write" class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 w-full rounded-2xl border border-transparent outline outline-1 outline-transparent onload-animation press-effect" data-stagger-index="5">
      <div class="card-body p-2 sm:p-4 flex flex-row items-center gap-2 sm:gap-3">
        <div class="rounded-full bg-warning/10 p-2 sm:p-3 flex-shrink-0">
          <Icon name="lucide:square-pen" class="w-4 h-4 sm:w-6 sm:h-6 text-warning" />
        </div>
        <div class="min-w-0 flex-1">
          <h2 class="card-title text-xs sm:text-lg leading-tight mb-0.5">写作台</h2>
          <p class="text-[10px] sm:text-sm opacity-75 truncate">配置站点、生成摘要与管理内容</p>
        </div>
      </div>
    </a>
  </CardGroup>

  <!-- Announcement -->
  <div class="onload-animation" data-stagger-index="6">
    <Announcement />
  </div>

  <!-- Blog Post List -->
  <CardGroup cols="1">
    {
      page.data.map((blog: Post, index: number) => (
        <div class="onload-animation" data-stagger-index={7 + index}>
          <PostCard
            title={blog.data.title}
            image={blog.data.image}
            description={blog.data.description}
            url={"/blog/" + blog.slug}
            pubDate={blog.data.pubDate}
            badge={blog.data.badge}
            categories={blog.data.categories}
            tags={blog.data.tags}
            word={blog.remarkPluginFrontmatter.totalCharCount}
            time={blog.remarkPluginFrontmatter.readingTime}
          />
        </div>
      ))
    }
  </CardGroup>
  <div class="onload-animation" data-stagger-index={7 + page.data.length}>
    <Pagination page={page} totalPages={totalPages} pageLinks={pageLinks} baseUrl={``} />
  </div>
</BaseLayout>
