---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Card from "@/components/temple/Card.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";

// 你的个人信息配置
const profile = {
  name: "MhYa123",
  avatar: "https://github.com/MhYa123.png", // 假设你的GitHub用户名是 MhYa123，如果不是请修改
  github: "https://github.com/MhYa123",
  twitter: "https://twitter.com/your_twitter_id", // 请替换
  email: "mailto:your_email@example.com", // 请替换
  location: "Japan",
};

// 你的技术栈数据 (根据你的记忆定制: Node, Nest, Vue, Prisma, Nginx, XenForo 等)
const techStack = [
  { name: "Node.js", icon: "simple-icons:nodedotjs", color: "#339933" },
  { name: "NestJS", icon: "simple-icons:nestjs", color: "#E0234E" },
  { name: "Vue.js", icon: "simple-icons:vuedotjs", color: "#4FC08D" },
  { name: "TypeScript", icon: "simple-icons:typescript", color: "#3178C6" },
  { name: "Prisma", icon: "simple-icons:prisma", color: "#2D3748" },
  { name: "MySQL", icon: "simple-icons:mysql", color: "#4479A1" },
  { name: "Nginx", icon: "simple-icons:nginx", color: "#009639" },
  { name: "Docker", icon: "simple-icons:docker", color: "#2496ED" },
  { name: "XenForo", icon: "lucide:message-square", color: "#F29D13" },// 如果没有这个图标，可以用 fa-solid:comments 代替
  { name: "Tailwind", icon: "simple-icons:tailwindcss", color: "#06B6D4" },
  { name: "Git", icon: "simple-icons:git", color: "#F05032" },
  { name: "Linux", icon: "simple-icons:linux", color: "#FCC624" },
];
---

<BaseLayout title="About" isIndexed={false}>
  <Card class="p-4 md:p-8">
    <div class="space-y-10 mb-8">
      <section class="flex flex-col md:flex-row gap-8 items-center md:items-start">
        <div class="avatar">
          <div
            class="w-32 h-32 md:w-40 md:h-40 rounded-xl ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden"
          >
            <img 
              src={profile.avatar} 
              alt={profile.name} 
              width="160" 
              height="160" 
              loading="eager" 
            />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-bold mb-2">{profile.name}</h1>
          <p class="text-xl text-base-content/80 mb-4">全栈开发者 & 服务器折腾爱好者</p>

          <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-6">
            <a
              href={profile.github}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 hover:btn-primary transition-all duration-200"
            >
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub</span>
            </a>
            <a
              href={profile.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 hover:btn-info transition-all duration-200"
            >
              <Icon name="lucide:twitter" class="w-4 h-4" />
              <span>Twitter</span>
            </a>
            <a href={profile.email} class="btn btn-sm btn-outline gap-2 hover:btn-secondary transition-all duration-200">
              <Icon name="lucide:mail" class="w-4 h-4" />
              <span>Email</span>
            </a>
          </div>

          <div class="text-base-content/80 leading-relaxed">
            <p>👋 你好！我是 {profile.name}</p>
            <p class="mt-2">💻 热衷于 <b>Node.js</b> 生态，专注于 <b>Vue</b> 前端交互与 <b>NestJS</b> 后端架构。同时也痴迷于服务器运维，喜欢折腾 Nginx 配置与性能优化。</p>
            <p class="mt-2">偶尔也会开发一些 XenForo 插件或维护社区论坛。</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:info" class="w-6 h-6 text-primary" />
          <span>关于本站</span>
        </h2>
        
        <div class="prose prose-base dark:prose-invert max-w-none">
          <p>
            这是我的个人博客，用来记录技术通过、生活琐事以及开发过程中的踩坑记录。基于 Astro 5.0+ & Tailwind CSS 构建。
          </p>
          
          <h3 class="text-xl font-bold mt-4 mb-2">🌟 核心特色</h3>
          <ul class="list-disc list-inside space-y-1">
            <li>🚀 <strong>极速体验</strong>：基于 Astro 构建，提供极速的访问速度</li>
            <li>🎨 <strong>优雅设计</strong>：使用 Tailwind CSS 与 daisyUI，支持深色/浅色主题</li>
            <li>📱 <strong>完美适配</strong>：移动端优先的响应式设计</li>
            <li>⚡ <strong>流畅动画</strong>：ClientRouter 实现丝滑的页面过渡效果</li>
          </ul>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          <span>开源贡献</span>
        </h2>

        <GitHubStats username="MhYa123" showLanguages={false} showCommitGraph={true} />
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:code-2" class="w-6 h-6 text-primary" />
          <span>技术栈</span>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {
            techStack.map((tech) => (
              <div class="group flex flex-col items-center justify-center p-4 bg-base-200 rounded-xl hover:bg-base-300 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 cursor-default">
                <div class="text-3xl mb-2 group-hover:scale-110 transition-transform duration-300" style={`color: ${tech.color}`}>
                  <Icon name={tech.icon} class="w-10 h-10" />
                </div>
                <span class="text-sm font-medium">{tech.name}</span>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </Card>
</BaseLayout>