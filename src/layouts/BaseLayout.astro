---
import {
  SITE_TAB,
  SITE_DESCRIPTION,
  SITE_FAVICON,
  SITE_LANGUAGE,
  SITE_THEME,
  umamiConfig,
  SITE_PAGES,
  DEFAULT_BANNER_MODE,
} from "@config";
import { ClientRouter } from "astro:transitions";
import ElementCrossing from "astro-vtbot/components/ElementCrossing.astro";
import PointerOnNavigation from "astro-vtbot/components/PointerOnNavigation.astro";
import Header from "@components/Header.astro";
import Sidebar from "@components/Sidebar.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import Banner from "@components/Banner.astro";
import MobileTOC from "@components/widgets/MobileTOC.astro";
import GlobalAudio from "@components/widgets/GlobalAudio.astro";
import CookieConsent from "@components/widgets/CookieConsent.astro";
import UpdateNotifier from "@components/widgets/UpdateNotifier";
import ReadingProgress from "@components/widgets/ReadingProgress.astro";
import BackToTop from "@components/widgets/BackToTop.astro";

const {
  title,
  description,
  image,
  pubDate,
  updatedDate,
  author,
  headings = [],
  showTOC = false,
  isIndexed = true,
  isPostPage = false,
  showSidebar = true,
  showBanner = true,
} = Astro.props;

// 根据当前路径从配置中获取 Banner 内容
const currentPath = Astro.url.pathname.replace("/", "") || "home";
const pageConfig = SITE_PAGES?.[currentPath];
const bannerTitle = pageConfig?.title || title || "";
const bannerSubtitle = pageConfig?.subtitle || "";
---

<!doctype html>
<html
  lang={SITE_LANGUAGE}
  style="background-color: var(--custom-page-bg)"
  data-theme={SITE_THEME.light}
  data-theme-type="light"
>
  <head>
    <script define:vars={{ SITE_THEME, DEFAULT_BANNER_MODE }} is:inline>
      (function () {
        const root = document.documentElement;
        const darkThemes = ["dark", "synthwave", "halloween", "forest", "black", "luxury", "dracula", "business", "night", "coffee"];
        const storedTheme = localStorage.getItem("theme") || SITE_THEME.light;
        const storedBannerMode = localStorage.getItem("banner-mode") || DEFAULT_BANNER_MODE;
        const themeType = storedTheme === SITE_THEME.dark || darkThemes.includes(storedTheme) ? "dark" : "light";

        root.setAttribute("data-theme", storedTheme);
        root.setAttribute("data-theme-type", themeType);
        root.setAttribute("data-banner-mode", storedBannerMode);
        root.classList.toggle("dark", themeType === "dark");
        root.style.colorScheme = themeType;
      })();
    </script>
    <ClientRouter />
    <ElementCrossing />
    <PointerOnNavigation />
    <Header
      title={title}
      description={description || SITE_DESCRIPTION}
      favicon={SITE_FAVICON}
      image={image}
      isPostPage={isPostPage}
      pubDate={pubDate}
      updatedDate={updatedDate}
      author={author}
      isIndexed={isIndexed}
    />
    <title>{title ? `${title} - ${SITE_TAB}` : SITE_TAB}</title>

    <!-- 防止静态网页被浏览器和 CDN 强缓存导致更新后依然显示老数据 -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <!-- Google Fonts 预连接 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- 中文字体：异步加载，不阻塞渲染 -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;700&family=LXGW+WenKai:wght@400;700&family=ZCOOL+XiaoWei&family=Ma+Shan+Zheng&family=Long+Cang&family=ZCOOL+QingKe+HuangYou&family=ZCOOL+KuaiLe&family=Liu+Jian+Mao+Cao&family=Zhi+Mang+Xing&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;700&family=LXGW+WenKai:wght@400;700&family=ZCOOL+XiaoWei&family=Ma+Shan+Zheng&family=Long+Cang&family=ZCOOL+QingKe+HuangYou&family=ZCOOL+KuaiLe&family=Liu+Jian+Mao+Cao&family=Zhi+Mang+Xing&display=swap"
      />
    </noscript>

    <!-- 字体初始化（防闪烁 FOUC）-->
    <script is:inline>
      (function() {
        var font = localStorage.getItem('blog-font');
        if (font) {
          var el = document.createElement('style');
          el.id = 'blog-font-override';
          el.textContent = 'html, body, *, *::before, *::after { font-family: ' + font + ' !important; }';
          document.head.appendChild(el);
        }
      })();
    </script>

    <script is:inline>
      (function () {
        if (typeof window === "undefined" || window.__mahiroPinchZoomLocked) {
          return;
        }

        window.__mahiroPinchZoomLocked = true;

        const isTouchDevice = window.matchMedia("(pointer: coarse)").matches || "ontouchstart" in window;
        if (!isTouchDevice) {
          return;
        }

        const preventGestureZoom = (event) => {
          event.preventDefault();
        };

        const preventMultiTouchZoom = (event) => {
          if (event.touches.length > 1) {
            event.preventDefault();
          }
        };

        document.addEventListener("gesturestart", preventGestureZoom, { passive: false });
        document.addEventListener("gesturechange", preventGestureZoom, { passive: false });
        document.addEventListener("touchmove", preventMultiTouchZoom, { passive: false });
      })();
    </script>

    <script is:inline>
      (function () {
        if (typeof window === "undefined" || window.__mahiroViewportResizeOptimized) {
          return;
        }

        window.__mahiroViewportResizeOptimized = true;

        var root = document.documentElement;
        var resizeTimer = 0;
        var lastWidth = window.innerWidth;
        var lastHeight = window.innerHeight;
        var lastPixelRatio = window.devicePixelRatio || 1;

        var finishResize = function () {
          root.classList.remove("mahiro-viewport-resizing");
          root.style.removeProperty("--mahiro-current-device-pixel-ratio");
        };

        var markResizing = function () {
          var width = window.innerWidth;
          var height = window.innerHeight;
          var pixelRatio = window.devicePixelRatio || 1;
          var changed =
            width !== lastWidth ||
            height !== lastHeight ||
            Math.abs(pixelRatio - lastPixelRatio) > 0.001;

          lastWidth = width;
          lastHeight = height;
          lastPixelRatio = pixelRatio;

          if (!changed) {
            return;
          }

          root.classList.add("mahiro-viewport-resizing");
          root.style.setProperty("--mahiro-current-device-pixel-ratio", String(pixelRatio));
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(finishResize, 260);
        };

        window.addEventListener("resize", markResizing, { passive: true });
        window.visualViewport?.addEventListener("resize", markResizing, { passive: true });
        document.addEventListener("visibilitychange", function () {
          if (document.visibilityState === "visible") {
            finishResize();
          }
        });
      })();
    </script>

    <!-- Umami分析（自建） -->
    {
      umamiConfig.enable && umamiConfig.websiteId && (
        <script
          is:inline
          async
          src={`${umamiConfig.baseUrl}/script.js`}
          data-website-id={umamiConfig.websiteId}
        />
      )
    }
    {
      umamiConfig.enable && (
        <script is:inline defer src="/js/umami-share.js"></script>
      )
    }

    <!-- Microsoft Clarity -->
    <script type="text/javascript" is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "skz108rus8");
    </script>

    <!-- 主题管理脚本 -->
    <script define:vars={{ SITE_THEME, DEFAULT_BANNER_MODE }} is:inline>
      (function () {
        const root = document.documentElement;
        const darkThemes = ['dark', 'synthwave', 'halloween', 'forest', 'black', 'luxury', 'dracula', 'business', 'night', 'coffee'];
        const systemThemeMedia = window.matchMedia("(prefers-color-scheme: dark)");
        const resolveThemeType = (theme) => {
          return theme === SITE_THEME.dark || darkThemes.includes(theme) ? "dark" : "light";
        };
        const notifyThemeChange = (theme) => {
          const themeType = resolveThemeType(theme);
          window.dispatchEvent(new CustomEvent("mahiro:theme-change", {
            detail: {
              theme,
              themeType,
              isDark: themeType === "dark",
            },
          }));
        };
        const applyTheme = (theme, options = {}) => {
          const resolvedTheme = theme || SITE_THEME.light;
          const themeType = resolveThemeType(resolvedTheme);
          const shouldPersist = options.persist !== false;
          const shouldAnimate =
            options.animate === true &&
            typeof window.__mahiroRunThemeTransition === "function" &&
            window.matchMedia &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const currentTheme = root.getAttribute("data-theme");
          const currentThemeType = root.getAttribute("data-theme-type");
          const nextTransitionId = (window.__mahiroThemeTransitionId || 0) + 1;
          window.__mahiroThemeTransitionId = nextTransitionId;
          const clearThemeAnimationState = () => {
            clearTimeout(window.__mahiroThemeSwitchTimer);
            cancelAnimationFrame(window.__mahiroThemeSwitchFrame || 0);
            root.classList.remove("theme-switching");
            root.removeAttribute("data-theme-transition");
          };
          const commitTheme = () => {
            root.setAttribute("data-theme-type", themeType);
            root.setAttribute("data-theme", resolvedTheme);
            root.classList.toggle("dark", themeType === "dark");
            root.style.colorScheme = themeType;

            if (shouldPersist) {
              localStorage.setItem("theme", resolvedTheme);
            }

            notifyThemeChange(resolvedTheme);
          };

          if (currentTheme === resolvedTheme && currentThemeType === themeType) {
            if (shouldPersist && localStorage.getItem("theme") !== resolvedTheme) {
              localStorage.setItem("theme", resolvedTheme);
            }

            return resolvedTheme;
          }

          clearThemeAnimationState();

          if (shouldAnimate) {
            root.setAttribute("data-theme-transition", "fade");
            window.__mahiroRunThemeTransition(commitTheme, { targetThemeType: themeType })
              .catch(() => {
                commitTheme();
              })
              .finally(() => {
                if (window.__mahiroThemeTransitionId === nextTransitionId) {
                  clearThemeAnimationState();
                }
              });
            return resolvedTheme;
          }

          commitTheme();

          return resolvedTheme;
        };

        window.__mahiroResolveThemeType = resolveThemeType;
        window.__mahiroApplyTheme = applyTheme;
        window.__mahiroToggleTheme = (options = {}) => {
          const currentTheme = root.getAttribute("data-theme") || SITE_THEME.light;
          const nextTheme = currentTheme === SITE_THEME.light ? SITE_THEME.dark : SITE_THEME.light;
          return applyTheme(nextTheme, options);
        };
        const storedTheme = localStorage.getItem("theme");
        const storedBannerMode = localStorage.getItem("banner-mode") || DEFAULT_BANNER_MODE;
        let theme;
        if (storedTheme) {
          theme = storedTheme;
        } else {
          theme = SITE_THEME.light;
          localStorage.setItem("theme", theme);
        }
        root.setAttribute("data-banner-mode", storedBannerMode);
        applyTheme(theme, { animate: false });
        systemThemeMedia.addEventListener("change", (e) => {
            if (!localStorage.getItem("theme")) {
              const newTheme = e.matches ? SITE_THEME.dark : SITE_THEME.light;
              applyTheme(newTheme, { persist: false, animate: false });
            }
          });
      })();
    </script>
  </head>

  <!-- 移除上边距，让Banner从顶部开始 -->
  <body
    transition:animate="none"
    class="flex flex-col min-h-screen bg-[var(--banner-wave-bg)]"
    {...isIndexed ? { "data-pagefind-body": true } : {}}
  >
    {showBanner && <Banner title={bannerTitle} subtitle={bannerSubtitle} />}
    <Navbar />
    <ReadingProgress />
    <div class={`max-w-blog mx-auto w-full flex-grow page-content-animate ${showBanner ? 'mt-8' : 'mt-24'}`}>
      <div
        class={`grid grid-cols-1 ${showSidebar ? "md:grid-cols-5 lg:grid-cols-4" : ""} gap-4 px-4 pb-4 h-full`}
      >
        <main
          class={`col-span-1 ${showSidebar ? "md:col-span-4 lg:col-span-3" : "w-full"} bg-transparent order-1 md:order-2 flex flex-col gap-4`}
        >
          <div class="flex-grow flex flex-col gap-4">
            <slot />
          </div>
          <Footer />
        </main>
        {
          showSidebar && (
            <aside class="col-span-1 bg-transparent order-2 md:order-1 md:top-4 hidden md:block">
              <Sidebar headings={headings} showTOC={showTOC} />
              <slot name="sidebar" />
            </aside>
          )
        }
      </div>
    </div>


    <MobileTOC headings={headings} showTOC={showTOC} />
    <GlobalAudio />
    <CookieConsent />
    <UpdateNotifier client:only="react" />
    <BackToTop />

    <!-- 其余脚本保持不变 -->
    <script define:vars={{ SITE_THEME, DEFAULT_BANNER_MODE }} is:inline>
      document.addEventListener("astro:before-swap", (event) => {
        const newDocument = event.newDocument;
        const nextRoot = newDocument?.documentElement;
        if (!nextRoot) {
          return;
        }

        const nextTheme =
          localStorage.getItem("theme") ||
          document.documentElement.getAttribute("data-theme") ||
          SITE_THEME.light;
        const nextThemeType =
          window.__mahiroResolveThemeType?.(nextTheme) ||
          document.documentElement.getAttribute("data-theme-type") ||
          "light";
        const nextBannerMode =
          localStorage.getItem("banner-mode") ||
          document.documentElement.getAttribute("data-banner-mode") ||
          DEFAULT_BANNER_MODE;

        nextRoot.setAttribute("data-theme", nextTheme);
        nextRoot.setAttribute("data-theme-type", nextThemeType);
        nextRoot.setAttribute("data-banner-mode", nextBannerMode);
        nextRoot.classList.toggle("dark", nextThemeType === "dark");
        nextRoot.style.colorScheme = nextThemeType;
      });

      document.addEventListener("astro:after-swap", () => {
        const storedTheme = localStorage.getItem("theme");
        const storedBannerMode = localStorage.getItem("banner-mode") || DEFAULT_BANNER_MODE;
        
        if (storedTheme) {
          window.__mahiroApplyTheme?.(storedTheme, { persist: false, animate: false });
        }
        
        document.documentElement.setAttribute("data-banner-mode", storedBannerMode);
      });
    </script>

    <script>
      import gsap from "gsap";
      import NProgress from "nprogress";
      import "nprogress/nprogress.css";
      import { initAnimateValues } from "@/lib/animate-value";
      import { initClickParticles } from "@/lib/click-particles";
      import { initScrollReveal } from "@/lib/scroll-reveal";
      import { initHoverEffects } from "@/lib/hover-effects";
      import { initPageEntrance } from "@/lib/page-entrance";
      import { initSmoothTransitions } from "@/lib/smooth-transitions";
      import { decorateAiSummaryCards } from "@/lib/ai-summary-cards";

      const mahiroWindow = window as typeof window & {
        __mahiroClientAnimationHelpersReady?: boolean;
        __mahiroThemeTransitionId?: number;
        __mahiroSetThemeTrigger?: (element?: Element | null) => void;
        __mahiroEnsureThemeTrigger?: () => void;
        __mahiroAnimateThemeControl?: (element?: Element | null) => void;
        __mahiroRunThemeTransition?: (
          commitTheme: () => void,
          options?: { targetThemeType?: "light" | "dark" },
        ) => Promise<void>;
        __mahiroAnimateTranslateSuggestion?: (element?: Element | null) => Promise<void>;
        __mahiroDismissTranslateSuggestion?: (element?: Element | null) => Promise<void>;
      };

      if (!mahiroWindow.__mahiroClientAnimationHelpersReady) {
        mahiroWindow.__mahiroClientAnimationHelpersReady = true;

        const root = document.documentElement;
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
        const THEME_ORIGIN_X = "--mahiro-theme-origin-x";
        const THEME_ORIGIN_Y = "--mahiro-theme-origin-y";
        const THEME_RADIUS = "--mahiro-theme-reveal-radius";

        const setThemeTrigger = (element?: Element | null) => {
          const target = element instanceof Element ? element : null;
          const rect = target?.getBoundingClientRect();
          const x = rect ? rect.left + rect.width / 2 : window.innerWidth / 2;
          const y = rect ? rect.top + rect.height / 2 : window.innerHeight / 2;
          const radius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y),
          );

          root.style.setProperty(THEME_ORIGIN_X, `${x}px`);
          root.style.setProperty(THEME_ORIGIN_Y, `${y}px`);
          root.style.setProperty(THEME_RADIUS, `${Math.ceil(radius)}px`);
        };

        const ensureThemeTrigger = () => {
          if (!root.style.getPropertyValue(THEME_ORIGIN_X)) {
            setThemeTrigger(null);
          }
        };

        const animateThemeControl = (element?: Element | null) => {
          if (!(element instanceof HTMLElement) || prefersReducedMotion.matches) return;

          const icon = element.querySelector("svg, .theme-toggle-icon, .light-icon, .dark-icon");
          gsap.killTweensOf(element);
          gsap.fromTo(
            element,
            { scale: 0.97, force3D: true },
            {
              scale: 1,
              duration: 0.22,
              ease: "power2.out",
              clearProps: "transform",
              force3D: true,
            },
          );

          if (icon instanceof Element) {
            gsap.killTweensOf(icon);
            gsap.fromTo(
              icon,
              { scale: 0.94, opacity: 0.82, force3D: true },
              {
                scale: 1,
                opacity: 1,
                duration: 0.2,
                ease: "power2.out",
                clearProps: "transform,opacity",
                force3D: true,
              },
            );
          }
        };

        const runThemeTransition = (
          commitTheme: () => void,
          options: { targetThemeType?: "light" | "dark" } = {},
        ) => {
          if (prefersReducedMotion.matches) {
            commitTheme();
            return Promise.resolve();
          }

          if (typeof document.startViewTransition === "function") {
            const transition = document.startViewTransition(() => {
              commitTheme();
            });

            return transition.finished.then(() => {
              root.style.colorScheme = options.targetThemeType || root.getAttribute("data-theme-type") || "light";
            });
          }

          const overlay = document.createElement("div");
          const bodyStyles = window.getComputedStyle(document.body);
          overlay.className = "mahiro-theme-fallback-overlay";
          overlay.style.position = "fixed";
          overlay.style.inset = "0";
          overlay.style.zIndex = "9999";
          overlay.style.pointerEvents = "none";
          overlay.style.background = bodyStyles.backgroundColor || "var(--custom-page-bg)";
          overlay.style.opacity = "0";
          overlay.style.willChange = "opacity";
          overlay.style.transform = "translateZ(0)";
          overlay.style.backfaceVisibility = "hidden";
          document.body.appendChild(overlay);

          return new Promise<void>((resolve) => {
            const timeline = gsap.timeline({
              defaults: {
                ease: "power2.out",
                force3D: true,
              },
              onComplete: () => {
                overlay.remove();
                resolve();
              },
            });

            timeline.to(overlay, {
              opacity: 0.12,
              duration: 0.1,
              onComplete: () => {
                commitTheme();
                overlay.style.background =
                  window.getComputedStyle(document.body).backgroundColor || "var(--custom-page-bg)";
              },
            });

            timeline.to(overlay, {
              opacity: 0,
              duration: 0.16,
            });
          });
        };

        const animateTranslateSuggestion = (
          element: Element | null | undefined,
          direction: "enter" | "leave" = "enter",
        ) => {
          if (!(element instanceof HTMLElement)) return Promise.resolve();
          if (prefersReducedMotion.matches) {
            if (direction === "enter") {
              element.style.opacity = "1";
            }
            return Promise.resolve();
          }

          gsap.killTweensOf(element);

          return new Promise<void>((resolve) => {
            if (direction === "enter") {
              gsap.fromTo(
                element,
                { autoAlpha: 0, x: 20, y: 16, scale: 0.94, filter: "blur(10px)", force3D: true },
                {
                  autoAlpha: 1,
                  x: 0,
                  y: 0,
                  scale: 1,
                  filter: "blur(0px)",
                  duration: 0.44,
                  ease: "power3.out",
                  clearProps: "transform,filter",
                  force3D: true,
                  onComplete: () => resolve(),
                },
              );
              return;
            }

            gsap.to(element, {
              autoAlpha: 0,
              x: 18,
              y: 12,
              scale: 0.96,
              filter: "blur(8px)",
              duration: 0.28,
              ease: "power2.in",
              force3D: true,
              onComplete: () => resolve(),
            });
          });
        };

        setThemeTrigger(null);
        mahiroWindow.__mahiroSetThemeTrigger = setThemeTrigger;
        mahiroWindow.__mahiroEnsureThemeTrigger = ensureThemeTrigger;
        mahiroWindow.__mahiroAnimateThemeControl = animateThemeControl;
        mahiroWindow.__mahiroRunThemeTransition = runThemeTransition;
        mahiroWindow.__mahiroAnimateTranslateSuggestion = (element: Element | null | undefined) =>
          animateTranslateSuggestion(element, "enter");
        mahiroWindow.__mahiroDismissTranslateSuggestion = (element: Element | null | undefined) =>
          animateTranslateSuggestion(element, "leave");
      }

      // 配置 NProgress
      NProgress.configure({ showSpinner: false, speed: 400, minimum: 0.2 });

      // 在页面开始请求时触发进度条
      document.addEventListener("astro:before-preparation", () => {
        NProgress.start();
      });

      // 劫持 Astro 的页面生命周期，使用 anime.js 驱动入场动画
      document.addEventListener("astro:page-load", () => {
        NProgress.done();

        // 1. 页面入场动画（Banner 标题淡入 + 容器位移 + 交错加载）
        initPageEntrance();

        // 2. 数字递增动画
        initAnimateValues();

        // 3. 点击粒子特效
        initClickParticles();

        // 4. 滚动入场动画
        initScrollReveal();

        // 5. 悬浮 & 点击交互特效
        initHoverEffects();

        // 6. 全局柔和过渡（弹性 hover、侧边栏入场、导航栏平滑等）
        initSmoothTransitions();
        decorateAiSummaryCards();

        // 7. TOC 滚动遮罩检测
        const tocNav = document.querySelector(".toc-nav") as HTMLElement | null;
        if (tocNav) {
          const checkOverflow = () => {
            if (tocNav.scrollHeight > tocNav.clientHeight) {
              tocNav.classList.add("is-overflowing");
            } else {
              tocNav.classList.remove("is-overflowing");
            }
          };
          checkOverflow();
          // 监听 resize
          const ro = new ResizeObserver(checkOverflow);
          ro.observe(tocNav);
        }
      });
    </script>
  </body>
</html>
