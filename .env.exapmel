# GitHub App Configuration
# You can use either PUBLIC_ or NEXT_PUBLIC_ prefix
# Get these values from your GitHub App settings

# Your GitHub Username
PUBLIC_GITHUB_OWNER=

# Your Repository Name
PUBLIC_GITHUB_REPO=

# Your Repository Branch (default: main)
PUBLIC_GITHUB_BRANCH=

# Your GitHub App ID (Found in GitHub App -> General -> App ID)
PUBLIC_GITHUB_APP_ID=

# Optional: Encryption key for storing Private Key in local storage
# PUBLIC_GITHUB_ENCRYPT_KEY=wudishiduomejimo

# Umami Website ID (For Analytics)
PUBLIC_UMAMI_WEBSITE_ID=

# Umami Share ID (For View/Visitor Counters)
PUBLIC_UMAMI_SHARE_ID=

# Post Encryption Password (Server-side only, NOT exposed to client)
# Used to encrypt/decrypt password-protected blog posts
POST_PASSWORD=your_secret_password

# AI Summary / OpenAI-Compatible API
# Recommended to rename this file to .env.example for consistency
# OPENAI_MODEL is only used as a compatibility/manual override value.
# Per-article model selection should be stored in frontmatter aiModel.
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen3.5-plus
OPENAI_TIMEOUT_MS=60000
OPENAI_RETRIES=3
