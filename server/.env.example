# Log language (zh = 中文, en = English)
LOG_LANG=zh

PORT=3000
ALLOWED_ORIGINS=*

# AList drive
ALIST_BASE_URL=https://s.mahiro.work
ALIST_USERNAME=mahiro
ALIST_PASSWORD=mahiro
# Optional: if you already have a long-lived token, you can use it instead
# ALIST_TOKEN=
# Optional: default root shown by the drive page
ALIST_ROOT_PATH=/
# Optional: upstream timeout in milliseconds
ALIST_TIMEOUT_MS=45000
# Optional: backend-enforced permissions
# Available values: upload,mkdir,view,download,rename,copy,move,remove
# Use comma-separated list, for example:
# ALIST_PERMISSIONS=view,download
ALIST_PERMISSIONS=upload,mkdir,view,download,rename,copy,move,remove

# API encryption
API_RSA_ENCRYPTION=true
API_RSA_CERT_DIR=certs
# API_RSA_PRIVATE_KEY_PATH=/absolute/path/to/api-rsa-private.pem
# API_RSA_PUBLIC_KEY_PATH=/absolute/path/to/api-rsa-public.pem

# AI summary (set to false to disable)
AI_SUMMARY_ENABLED=true
OPENAI_API_KEY=your_summary_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=60000
OPENAI_RETRIES=3

# AI translation (set to false to disable)
AI_TRANSLATE_ENABLED=true
AI_TRANSLATE_API_KEY=your_translate_api_key
AI_TRANSLATE_BASE_URL=https://api.openai.com/v1
AI_TRANSLATE_TIMEOUT_MS=60000
AI_TRANSLATE_RETRIES=3

# Redis cache (optional — falls back to in-memory cache if unavailable)
# Format: redis://[:password@]host[:port][/db]
# Examples:
#   redis://127.0.0.1:6379          (no password, db 0)
#   redis://127.0.0.1:6379/2        (no password, db 2)
#   redis://:mypassword@host:6379/3 (with password, db 3)
REDIS_URL=redis://127.0.0.1:6379
# Key prefix for all cached data (default: mahiro:)
REDIS_KEY_PREFIX=mahiro:

# Cache configuration
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL_LIST=300
CACHE_TTL_ITEM=3600
CACHE_TTL_SEARCH=60
