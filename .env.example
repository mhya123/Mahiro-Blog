# GitHub App Configuration
# You can use either PUBLIC_ or NEXT_PUBLIC_ prefix
# Get these values from your GitHub App settings

# Your GitHub Username
PUBLIC_GITHUB_OWNER=your_github_owner

# Your Repository Name
PUBLIC_GITHUB_REPO=your_repository_name

# Your Repository Branch (default: main)
PUBLIC_GITHUB_BRANCH=main

# Your GitHub App ID (Found in GitHub App -> General -> App ID)
PUBLIC_GITHUB_APP_ID=your_github_app_id

# Optional: Encryption key for storing Private Key in local storage
# PUBLIC_GITHUB_ENCRYPT_KEY=your_encrypt_key

# Umami Website ID (For Analytics)
PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id

# Umami Share ID (For View/Visitor Counters)
PUBLIC_UMAMI_SHARE_ID=your_umami_share_id

# External backend base URL
PUBLIC_SITE_API_BASE_URL=https://back.mahiro.work

# Local dev backend override
# MAHIRO_SERVER_PORT=50001
# MAHIRO_LOCAL_API_BASE_URL=http://127.0.0.1:50001

# Post Encryption Password (Server-side only, NOT exposed to client)
POST_PASSWORD=your_post_password

# Backend AI service variables have been moved to:
# server/.env
# server/.env.example
